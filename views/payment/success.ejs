<%- include('../includes/navbar') %>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Booking Confirmed | Wanderlust</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --sand: #f5f0e8;
      --cream: #faf7f2;
      --ink: #1a1a2e;
      --muted: #6b6b7b;
      --accent: #c9783a;
      --accent-light: #f0dcc8;
      --gold: #d4a843;
      --success: #2d7a4f;
      --border: #e0d8cc;
      --white: #ffffff;
      --shadow: 0 8px 40px rgba(26,26,46,0.10);
      --radius: 18px;
    }

    body {
      background: var(--cream);
      font-family: 'DM Sans', sans-serif;
      color: var(--ink);
      min-height: 100vh;
    }

    .success-wrapper {
      max-width: 640px;
      margin: 0 auto;
      padding: 60px 20px 100px;
    }

    /* ── Animated checkmark ── */
    .check-circle {
      width: 88px;
      height: 88px;
      border-radius: 50%;
      background: rgba(45,122,79,0.1);
      border: 2.5px solid var(--success);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 28px;
      animation: popIn 0.5s cubic-bezier(0.34,1.56,0.64,1) both;
    }

    .check-circle i {
      font-size: 36px;
      color: var(--success);
    }

    @keyframes popIn {
      from { opacity: 0; transform: scale(0.5); }
      to   { opacity: 1; transform: scale(1); }
    }

    .success-title {
      font-family: 'Playfair Display', serif;
      font-size: 32px;
      text-align: center;
      color: var(--ink);
      margin-bottom: 8px;
      animation: fadeUp 0.5s 0.15s ease both;
    }

    .success-sub {
      text-align: center;
      font-size: 14px;
      color: var(--muted);
      margin-bottom: 40px;
      line-height: 1.7;
      animation: fadeUp 0.5s 0.25s ease both;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Main card ── */
    .confirm-card {
      background: var(--white);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow: hidden;
      animation: fadeUp 0.5s 0.3s ease both;
    }

    /* Listing image */
    .confirm-img {
      width: 100%;
      height: 200px;
      object-fit: cover;
      display: block;
    }

    .confirm-img-placeholder {
      width: 100%;
      height: 200px;
      background: linear-gradient(135deg, #1a1a2e, #2e2640);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 3rem;
    }

    .confirm-body { padding: 32px 36px; }

    /* Destination heading */
    .dest-tag {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 6px;
    }

    .dest-name {
      font-family: 'Playfair Display', serif;
      font-size: 24px;
      color: var(--ink);
      margin-bottom: 4px;
    }

    .dest-loc {
      font-size: 13px;
      color: var(--muted);
      display: flex;
      align-items: center;
      gap: 5px;
      margin-bottom: 28px;
    }

    /* Details grid */
    .details-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-bottom: 24px;
    }

    .detail-box {
      background: var(--cream);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 14px 16px;
    }

    .detail-box .d-label {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 5px;
    }

    .detail-box .d-val {
      font-size: 14px;
      font-weight: 600;
      color: var(--ink);
    }

    /* Amount row */
    .amount-row {
      background: var(--ink);
      border-radius: 12px;
      padding: 20px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
    }

    .amount-row .a-label {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: rgba(255,255,255,0.45);
    }

    .amount-row .a-val {
      font-family: 'Playfair Display', serif;
      font-size: 28px;
      color: var(--gold);
    }

    .amount-row .a-pid {
      font-size: 11px;
      color: rgba(255,255,255,0.3);
      margin-top: 3px;
    }

    /* Email notice */
    .email-notice {
      display: flex;
      align-items: center;
      gap: 12px;
      background: rgba(45,122,79,0.07);
      border: 1px solid rgba(45,122,79,0.2);
      border-radius: 10px;
      padding: 14px 18px;
      margin-bottom: 28px;
    }

    .email-notice i { font-size: 20px; color: var(--success); flex-shrink: 0; }
    .email-notice p { font-size: 13px; color: var(--ink); line-height: 1.5; margin: 0; }
    .email-notice p span { font-weight: 600; }

    /* CTA buttons */
    .cta-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .btn-primary {
      padding: 14px;
      background: linear-gradient(135deg, var(--accent), #a85e28);
      color: white;
      border: none;
      border-radius: 10px;
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      text-align: center;
      display: block;
      transition: all 0.2s;
      box-shadow: 0 4px 16px rgba(201,120,58,0.3);
    }

    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(201,120,58,0.4); }

    .btn-outline {
      padding: 14px;
      background: transparent;
      color: var(--ink);
      border: 2px solid var(--border);
      border-radius: 10px;
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      text-align: center;
      display: block;
      transition: all 0.2s;
    }

    .btn-outline:hover { border-color: var(--accent); color: var(--accent); }

    @media (max-width: 520px) {
      .details-grid { grid-template-columns: 1fr; }
      .cta-row { grid-template-columns: 1fr; }
      .confirm-body { padding: 24px 20px; }
    }
  </style>
</head>
<body>

<div class="success-wrapper">

  <!-- Animated check -->
  <div class="check-circle">
    <i class="fa-solid fa-check"></i>
  </div>

  <h1 class="success-title">You're all set! 🎉</h1>
  <p class="success-sub">
    Your payment was successful and your booking is confirmed.<br/>
    A confirmation email has been sent to your inbox.
  </p>

  <!-- Confirmation Card -->
  <div class="confirm-card">

    <!-- Listing image -->
    <% if(booking.listing.image && booking.listing.image.url) { %>
      <img src="<%= booking.listing.image.url %>" alt="<%= booking.listing.title %>" class="confirm-img"/>
    <% } else { %>
      <div class="confirm-img-placeholder">🌍</div>
    <% } %>

    <div class="confirm-body">

      <p class="dest-tag">✦ Booking Confirmed</p>
      <h2 class="dest-name"><%= booking.listing.title %></h2>
      <p class="dest-loc">
        <i class="fa-solid fa-location-dot"></i>
        <%= booking.listing.location %>, <%= booking.listing.country %>
      </p>

      <!-- Details grid -->
      <div class="details-grid">
        <div class="detail-box">
          <div class="d-label">Check-in</div>
          <div class="d-val">
            <% if(booking.checkIn) { %>
              📅 <%= new Date(booking.checkIn).toDateString() %>
            <% } else { %> — <% } %>
          </div>
        </div>
        <div class="detail-box">
          <div class="d-label">Check-out</div>
          <div class="d-val">
            <% if(booking.checkOut) { %>
              📅 <%= new Date(booking.checkOut).toDateString() %>
            <% } else { %> — <% } %>
          </div>
        </div>
        <div class="detail-box">
          <div class="d-label">Guests</div>
          <div class="d-val">👤 <%= booking.guests || 1 %> Guest<%= (booking.guests || 1) > 1 ? 's' : '' %></div>
        </div>
        <div class="detail-box">
          <div class="d-label">Booking Ref</div>
          <div class="d-val">#<%= booking._id.toString().slice(-8).toUpperCase() %></div>
        </div>
      </div>

      <!-- Amount -->
      <div class="amount-row">
        <div>
          <div class="a-label">Total Paid</div>
          <div class="a-pid">Payment ID: <%= booking.paymentId %></div>
        </div>
        <div class="a-val">₹<%= booking.totalPrice.toLocaleString('en-IN') %></div>
      </div>

      <!-- Email notice -->
      <div class="email-notice">
        <i class="fa-solid fa-envelope-circle-check"></i>
        <p>A detailed confirmation has been sent to <span><%= user ? user.email : 'your email' %></span>. Check your inbox (and spam folder).</p>
      </div>

      <!-- CTAs -->
      <div class="cta-row">
        <a href="/listings" class="btn-primary">
          <i class="fa-solid fa-compass"></i> &nbsp;Explore More
        </a>
        <a href="/bookings" class="btn-outline">
          <i class="fa-solid fa-calendar-check"></i> &nbsp;My Bookings
        </a>
      </div>

    </div>
  </div>

</div>

</body>
</html>
