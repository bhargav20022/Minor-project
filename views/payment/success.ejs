<% layout("/layouts/boilerplate") %>

<style>
.receipt-page { background:#f5f1eb; min-height:80vh; padding:40px 0; }
.receipt-wrap { max-width:680px; margin:0 auto; padding:0 16px; }
.receipt-actions { display:flex; gap:12px; justify-content:center; margin-bottom:28px; flex-wrap:wrap; }
.receipt-btn {
  display:inline-flex; align-items:center; gap:8px;
  padding:13px 26px; border-radius:50px; font-family:'DM Sans',sans-serif;
  font-size:14px; font-weight:600; cursor:pointer; border:none; transition:all .22s; text-decoration:none;
}
.btn-download { background:linear-gradient(135deg,#1a1a2e,#2d2250); color:#fff; }
.btn-download:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(26,26,46,.35); color:#fff; }
.btn-home { background:white; color:#1a1a2e; border:1.5px solid #e0d8cc; }
.btn-home:hover { border-color:#c9783a; color:#c9783a; transform:translateY(-2px); }

/* ── Receipt Card ── */
#receiptCard {
  background:#fff; border-radius:24px;
  box-shadow:0 6px 36px rgba(26,26,46,.12); overflow:hidden;
}
.receipt-header {
  background:linear-gradient(135deg,#1a1a2e 0%,#2d2250 100%);
  padding:36px 40px 30px; text-align:center; position:relative; overflow:hidden;
}
.receipt-header::before {
  content:''; position:absolute; inset:0;
  background:radial-gradient(ellipse 60% 70% at 50% 120%, rgba(212,168,67,.2) 0%,transparent 65%);
  pointer-events:none;
}
.receipt-brand { font-family:'Cormorant Garamond',serif; font-size:13px; letter-spacing:4px; text-transform:uppercase; color:#d4a843; margin-bottom:16px; position:relative; }
.receipt-status-icon { font-size:52px; margin-bottom:14px; display:block; position:relative; animation:popIn .5s cubic-bezier(.34,1.56,.64,1); }
@keyframes popIn { from{transform:scale(0);opacity:0} to{transform:scale(1);opacity:1} }
.receipt-header h1 { font-family:'Cormorant Garamond',serif; font-size:32px; font-weight:600; color:#fff; margin:0 0 8px; position:relative; }
.receipt-header p { font-family:'DM Sans',sans-serif; font-size:13px; color:rgba(255,255,255,.45); margin:0; position:relative; }
.receipt-paid-badge {
  display:inline-flex; align-items:center; gap:7px; margin-top:16px; position:relative;
  background:rgba(76,175,80,.2); border:1.5px solid rgba(76,175,80,.5); border-radius:30px;
  padding:7px 18px; font-family:'DM Sans',sans-serif; font-size:13px; font-weight:600; color:#4caf7d;
}

/* Divider */
.receipt-divider { display:flex; align-items:center; position:relative; background:#1a1a2e; }
.receipt-divider::before,.receipt-divider::after {
  content:''; flex:1; height:1px; background:rgba(255,255,255,.1);
}
.divider-circle {
  width:22px; height:22px; border-radius:50%; background:#f5f1eb;
  box-shadow:inset 0 0 0 4px #1a1a2e; margin:0 -1px; flex-shrink:0;
}
.divider-circles { display:flex; align-items:center; padding:0 20px; gap:8px; }
.divider-dot { width:6px; height:6px; border-radius:50%; background:rgba(255,255,255,.15); }

/* Body */
.receipt-body { padding:36px 40px; }
@media(max-width:480px) { .receipt-body { padding:24px 20px; } .receipt-header { padding:28px 20px 24px; } }

.receipt-section-label { font-family:'DM Sans',sans-serif; font-size:10px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#7a7a8a; margin-bottom:14px; display:flex; align-items:center; gap:8px; }
.receipt-section-label::after { content:''; flex:1; height:1px; background:#e0d8cc; }

.receipt-listing-row { display:flex; gap:16px; align-items:center; background:#faf7f2; border-radius:14px; padding:16px; margin-bottom:24px; border:1px solid #e0d8cc; }
.receipt-listing-img { width:70px; height:70px; border-radius:10px; object-fit:cover; flex-shrink:0; }
.receipt-listing-info .title { font-family:'DM Sans',sans-serif; font-size:15px; font-weight:600; color:#1a1a2e; margin-bottom:4px; }
.receipt-listing-info .loc { font-size:12px; color:#7a7a8a; display:flex; align-items:center; gap:4px; }

.receipt-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:24px; }
@media(max-width:400px) { .receipt-grid { grid-template-columns:1fr; } }
.receipt-detail { background:#faf7f2; border-radius:12px; padding:14px 16px; border:1px solid #e0d8cc; }
.receipt-detail .lbl { font-family:'DM Sans',sans-serif; font-size:10px; font-weight:600; letter-spacing:1px; text-transform:uppercase; color:#7a7a8a; margin-bottom:5px; }
.receipt-detail .val { font-family:'DM Sans',sans-serif; font-size:14px; font-weight:600; color:#1a1a2e; }

.receipt-total-box { background:#1a1a2e; border-radius:16px; padding:22px 24px; margin-bottom:24px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; }
.receipt-total-box .lbl { font-family:'DM Sans',sans-serif; font-size:12px; color:rgba(255,255,255,.45); margin-bottom:4px; }
.receipt-total-box .amount { font-family:'Cormorant Garamond',serif; font-size:36px; font-weight:600; color:#d4a843; line-height:1; }
.receipt-total-box .pid { font-family:'DM Sans',sans-serif; font-size:11px; color:rgba(255,255,255,.3); margin-top:5px; }
.receipt-total-box .status-pill { background:rgba(76,175,80,.2); border:1.5px solid rgba(76,175,80,.4); border-radius:30px; padding:8px 18px; font-family:'DM Sans',sans-serif; font-size:13px; font-weight:600; color:#4caf7d; }

.receipt-footer { text-align:center; padding-top:20px; border-top:1px solid #e0d8cc; }
.receipt-footer p { font-family:'DM Sans',sans-serif; font-size:12px; color:#7a7a8a; line-height:1.7; margin:0 0 6px; }
.receipt-footer .brand { font-family:'Cormorant Garamond',serif; font-size:16px; font-weight:600; color:#1a1a2e; letter-spacing:2px; }
</style>

<div class="receipt-page">
  <div class="receipt-wrap">

    <!-- Action Buttons -->
    <div class="receipt-actions">
      <button class="receipt-btn btn-download" onclick="downloadReceipt()">
        <i class="fa-solid fa-download"></i> Download Receipt
      </button>
      <a href="/listings" class="receipt-btn btn-home">
        <i class="fa-solid fa-house"></i> Back to Home
      </a>
    </div>

    <!-- Receipt Card -->
    <div id="receiptCard">
      <div class="receipt-header">
        <div class="receipt-brand">✦ Wanderlust</div>
        <span class="receipt-status-icon">🎉</span>
        <h1>Booking Confirmed!</h1>
        <p>Your adventure is officially locked in</p>
        <div class="receipt-paid-badge">✓ &nbsp;Payment Successful</div>
      </div>

      <!-- Ticket-style tear -->
      <div class="receipt-divider">
        <div class="divider-circle"></div>
        <div class="divider-circles">
          <% for(let i=0;i<18;i++) { %><div class="divider-dot"></div><% } %>
        </div>
        <div class="divider-circle"></div>
      </div>

      <div class="receipt-body">

        <!-- Listing -->
        <div class="receipt-section-label">Destination</div>
        <div class="receipt-listing-row">
          <% if(booking.listing && booking.listing.image && booking.listing.image.url) { %>
            <img src="<%= booking.listing.image.url %>" alt="<%= booking.listing.title %>" class="receipt-listing-img"/>
          <% } %>
          <div class="receipt-listing-info">
            <div class="title"><%= booking.listing ? booking.listing.title : 'Your Stay' %></div>
            <div class="loc">
              <i class="fa-solid fa-location-dot" style="color:#c9783a;font-size:10px"></i>
              <%= booking.listing ? booking.listing.location + ', ' + booking.listing.country : '' %>
            </div>
          </div>
        </div>

        <!-- Trip Details -->
        <div class="receipt-section-label">Trip Details</div>
        <div class="receipt-grid">
          <div class="receipt-detail">
            <div class="lbl">Check-in</div>
            <div class="val">📅 <%= booking.checkIn ? new Date(booking.checkIn).toDateString() : '—' %></div>
          </div>
          <div class="receipt-detail">
            <div class="lbl">Check-out</div>
            <div class="val">📅 <%= booking.checkOut ? new Date(booking.checkOut).toDateString() : '—' %></div>
          </div>
          <div class="receipt-detail">
            <div class="lbl">Guests</div>
            <div class="val">👤 <%= booking.guests || 1 %> Guest<%= booking.guests > 1 ? 's' : '' %></div>
          </div>
          <div class="receipt-detail">
            <div class="lbl">Booking Ref</div>
            <div class="val">#<%= booking._id.toString().slice(-8).toUpperCase() %></div>
          </div>
        </div>

        <!-- Total -->
        <div class="receipt-section-label">Payment</div>
        <div class="receipt-total-box">
          <div>
            <div class="lbl">Total Amount Paid</div>
            <div class="amount">₹<%= booking.totalPrice ? booking.totalPrice.toLocaleString('en-IN') : '—' %></div>
            <div class="pid">Payment ID: <%= booking.paymentId || '—' %></div>
          </div>
          <div class="status-pill">✓ Paid</div>
        </div>

        <!-- Footer -->
        <div class="receipt-footer">
          <p>A confirmation email has been sent to your registered email address.</p>
          <p>Questions? Contact us at <strong>support@wanderlust.com</strong></p>
          <div class="brand">WANDERLUST</div>
        </div>

      </div>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script>
async function downloadReceipt() {
  const btn = document.querySelector('.btn-download');
  btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Generating...';
  btn.disabled = true;

  try {
    const card = document.getElementById('receiptCard');
    const canvas = await html2canvas(card, { scale: 2, useCORS: true, backgroundColor: '#ffffff' });
    const imgData = canvas.toDataURL('image/png');
    const { jsPDF } = window.jspdf;
    const pdf = new jsPDF({ orientation: 'portrait', unit: 'px', format: [canvas.width / 2, canvas.height / 2] });
    pdf.addImage(imgData, 'PNG', 0, 0, canvas.width / 2, canvas.height / 2);
    pdf.save('Wanderlust-Booking-Receipt.pdf');
  } catch(e) {
    alert('Could not generate PDF. Please try again.');
  }

  btn.innerHTML = '<i class="fa-solid fa-download"></i> Download Receipt';
  btn.disabled = false;
}
</script>
