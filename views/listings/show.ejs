<% layout("/layouts/boilerplate") %>

<!-- ✅ FIXED: pass mapToken from backend -->
<script>
  const mapToken = "<%= mapToken %>";
  const listing = <%- JSON.stringify(listing) %>;
</script>

<style>
  #map {
    height: 400px;
    width: 100%;
    border-radius: 12px;
  }
</style>

<div class="row">
  <div class="col-lg-8 col-md-10 col-sm-12 mx-auto">

    <!-- TITLE -->
    <h3 class="mt-3"><%= listing.title %></h3>

    <!-- IMAGE CARD -->
    <div class="card show-card listing-card">
      <img src="<%= listing.image.url %>" class="card-img-top show-img">
      <div class="card-body">
        <p><b>Hosted By:</b> <i><%= listing.owner.username %></i></p>
        <p><b>Description:</b> <%= listing.description %></p>
        <p><b>Price:</b> ₹ <%= listing.price.toLocaleString("en-IN") %></p>
        <p><b>Category:</b> <%= listing.category %></p>
        <p><b>Location:</b> <%= listing.location %></p>
        <p><b>Country:</b> <%= listing.country %></p>
      </div>
    </div>

    <!-- EDIT DELETE -->
    <% if(currUser && currUser._id.equals(listing.owner._id)) { %>
      <div class="mt-3">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-danger">Edit</a>
        <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" style="display:inline;">
          <button class="btn btn-dark">Delete</button>
        </form>
      </div>
    <% } %>

    <hr>

    <!-- ⭐ REVIEWS -->
    <% if(currUser) { %>
      <h4>Leave a Review</h4>
      <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation" novalidate>

        <fieldset class="starability-slot">
          <input type="radio" name="review[rating]" value="1" checked>
          <input type="radio" name="review[rating]" value="2">
          <input type="radio" name="review[rating]" value="3">
          <input type="radio" name="review[rating]" value="4">
          <input type="radio" name="review[rating]" value="5">
        </fieldset>

        <textarea name="review[comment]" class="form-control mt-2" required></textarea>
        <button class="btn btn-dark mt-2">Submit</button>
      </form>
    <% } %>

    <!-- ALL REVIEWS -->
    <% if(listing.reviews.length > 0) { %>
      <h4 class="mt-3">All Reviews</h4>
      <% listing.reviews.forEach(review => { %>
        <div class="card mt-2">
          <div class="card-body">
            <h6>@<%= review.author.username %></h6>
            <p><%= review.comment %></p>
          </div>
        </div>
      <% }) %>
    <% } %>

    <hr>

    <!-- 🏡 AMENITIES -->
    <h4>What this place offers</h4>
    <div class="offers">
      <i class="ri-restaurant-line"><span> Kitchen</span></i>
      <i class="ri-car-fill"><span> Parking</span></i>
      <i class="ri-wifi-line"><span> Wifi</span></i>
    </div>

    <hr>

    <!-- 📍 MAP -->
    <h4>Where you'll be</h4>
    <div id="map"></div>

    <hr>

    <!-- 💳 BOOKING -->
    <% if(currUser) { %>
    <div class="card p-4 mb-4">

      <form action="/booking/<%= listing._id %>" method="POST" id="bookingForm">

        <div class="row">
          <div class="col">
            <input type="date" id="checkIn" name="checkIn" class="form-control" required>
          </div>
          <div class="col">
            <input type="date" id="checkOut" name="checkOut" class="form-control" required>
          </div>
        </div>

        <select name="guests" class="form-control mt-2" required>
          <option disabled selected>Select guests</option>
          <option>1</option>
          <option>2</option>
          <option>3</option>
        </select>

        <div id="pricePreview" style="display:none;" class="mt-2">
          ₹ <span id="totalPreview"></span>
        </div>

        <button class="btn btn-success mt-3 w-100">Book Now</button>

      </form>
    </div>
    <% } %>

  </div>
</div>

<!-- ✅ MAP SCRIPT (FIXED FULLY) -->
<script>
  mapboxgl.accessToken = mapToken;

  const map = new mapboxgl.Map({
    container: "map",
    style: "mapbox://styles/mapbox/streets-v12",
    center: listing.geometry.coordinates,
    zoom: 9
  });

  new mapboxgl.Marker()
    .setLngLat(listing.geometry.coordinates)
    .addTo(map);
</script>

<!-- ✅ PRICE CALCULATION -->
<script>
  const pricePerNight = <%= listing.price %>;

  document.getElementById("checkIn").addEventListener("change", calc);
  document.getElementById("checkOut").addEventListener("change", calc);

  function calc() {
    const ci = new Date(document.getElementById("checkIn").value);
    const co = new Date(document.getElementById("checkOut").value);

    if (ci && co && co > ci) {
      const nights = (co - ci) / (1000*60*60*24);
      document.getElementById("pricePreview").style.display = "block";
      document.getElementById("totalPreview").innerText =
        (nights * pricePerNight).toLocaleString("en-IN");
    }
  }
</script>
