<% layout("/layouts/boilerplate") %>

<script>
  const mapToken = "<%= process.env.MAP_TOKEN %>";
  const listing  = <%- JSON.stringify(listing) %>;
</script>

<style>
  :root {
    --ink:#1a1a2e; --cream:#faf7f2; --accent:#c9783a; --accent-light:#f0dcc8;
    --gold:#d4a843; --muted:#6b6b7b; --border:#e0d8cc; --success:#2d7a4f;
    --white:#ffffff; --radius:16px; --shadow:0 8px 32px rgba(26,26,46,0.10);
  }
  .show-page{max-width:900px;margin:0 auto;padding:28px 16px 80px;}
  .show-hero{border-radius:20px;overflow:hidden;height:420px;position:relative;box-shadow:var(--shadow);margin-bottom:28px;}
  .show-hero img{width:100%;height:100%;object-fit:cover;display:block;}
  .show-hero-overlay{position:absolute;inset:0;background:linear-gradient(to bottom,transparent 40%,rgba(26,26,46,0.7) 100%);}
  .show-hero-info{position:absolute;bottom:24px;left:28px;right:28px;color:white;}
  .show-hero-info h2{font-family:'Playfair Display',serif;font-size:clamp(1.4rem,3vw,2rem);font-weight:700;margin:0 0 6px;}
  .show-hero-loc{font-size:14px;color:rgba(255,255,255,0.75);display:flex;align-items:center;gap:6px;}
  .show-grid{display:grid;grid-template-columns:1fr 320px;gap:28px;align-items:start;}
  @media(max-width:768px){.show-grid{grid-template-columns:1fr;}}
  .info-card{background:var(--white);border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden;margin-bottom:24px;}
  .info-card-header{background:var(--ink);padding:20px 24px;}
  .info-card-header .tag{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--gold);display:block;margin-bottom:6px;}
  .info-card-header h3{font-family:'Playfair Display',serif;font-size:1.25rem;color:white;margin:0;}
  .info-card-body{padding:20px 24px;}
  .info-row{display:flex;gap:12px;padding:11px 0;border-bottom:1px solid var(--border);font-size:14px;align-items:flex-start;}
  .info-row:last-child{border-bottom:none;}
  .info-row i{color:var(--accent);font-size:13px;margin-top:3px;flex-shrink:0;width:16px;}
  .info-label{color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:0.8px;margin-bottom:3px;}
  .info-val{font-weight:600;color:var(--ink);line-height:1.5;}
  .info-price{font-family:'Playfair Display',serif;font-size:1.6rem;font-weight:700;color:var(--accent);}
  .info-price-night{font-size:13px;font-weight:400;color:var(--muted);font-family:'DM Sans',sans-serif;}
  .booking-card{background:var(--white);border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden;position:sticky;top:24px;}
  .booking-card-header{background:linear-gradient(135deg,var(--ink),#2d2250);padding:20px 22px 16px;}
  .booking-card-header .tag{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--gold);display:block;margin-bottom:4px;}
  .booking-card-header h4{font-family:'Playfair Display',serif;font-size:1.05rem;color:white;margin:0;}
  .booking-card-body{padding:20px 20px 22px;}
  .bc-label{display:block;font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--muted);margin-bottom:6px;}
  .bc-input,.bc-select{width:100%;padding:11px 14px;border:2px solid var(--border);border-radius:10px;font-family:'DM Sans',sans-serif;font-size:14px;color:var(--ink);background:var(--cream);outline:none;transition:border-color .2s,box-shadow .2s;appearance:none;}
  .bc-input:focus,.bc-select:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(201,120,58,0.1);background:white;}
  .bc-stack{display:flex;flex-direction:column;gap:12px;margin-bottom:14px;}
  .bc-field{margin-bottom:14px;}
  .price-preview{display:none;background:var(--cream);border:1px solid var(--border);border-radius:10px;padding:12px 14px;margin-bottom:14px;}
  .pp-row{display:flex;justify-content:space-between;font-size:13px;color:var(--muted);margin-bottom:6px;}
  .pp-total{display:flex;justify-content:space-between;font-size:15px;font-weight:700;color:var(--ink);padding-top:8px;border-top:1px solid var(--border);}
  .btn-book{width:100%;padding:14px;background:linear-gradient(135deg,var(--accent),#a85e28);color:white;border:none;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:15px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:all .25s;box-shadow:0 4px 16px rgba(201,120,58,0.35);}
  .btn-book:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(201,120,58,0.45);}
  .btn-login-book{display:block;width:100%;padding:14px;background:var(--success);color:white;border:none;border-radius:10px;text-align:center;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;text-decoration:none;transition:all .2s;}
  .btn-login-book:hover{opacity:.9;color:white;}
  .reviews-section{margin-top:4px;}
  .section-head{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:600;color:var(--ink);margin-bottom:16px;display:flex;align-items:center;gap:10px;}
  .section-head::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,var(--border),transparent);}
  .review-form-card{background:var(--white);border-radius:var(--radius);box-shadow:var(--shadow);padding:22px;margin-bottom:20px;}
  .review-textarea{width:100%;padding:12px 14px;border:2px solid var(--border);border-radius:10px;font-family:'DM Sans',sans-serif;font-size:14px;resize:vertical;min-height:90px;outline:none;background:var(--cream);transition:border-color .2s;}
  .review-textarea:focus{border-color:var(--accent);background:white;}
  .btn-review{margin-top:10px;padding:10px 22px;background:var(--ink);color:white;border:none;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s;}
  .btn-review:hover{background:#2d2250;}
  .review-card{background:var(--white);border-radius:14px;padding:16px 20px;margin-bottom:12px;border:1px solid var(--border);}
  .review-author{font-weight:700;color:var(--ink);font-size:14px;margin-bottom:4px;}
  .review-comment{font-size:14px;color:var(--muted);line-height:1.6;}
  .btn-del-review{margin-top:10px;padding:5px 14px;background:transparent;border:1px solid var(--border);color:var(--muted);border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;transition:all .2s;font-family:'DM Sans',sans-serif;}
  .btn-del-review:hover{border-color:#dc3545;color:#dc3545;}
  .btn-gmaps{display:inline-flex;align-items:center;gap:6px;padding:9px 20px;border-radius:10px;border:2px solid var(--border);background:white;color:var(--ink);font-size:13px;font-weight:600;text-decoration:none;transition:all .2s;font-family:'DM Sans',sans-serif;}
  .btn-gmaps:hover{border-color:var(--accent);color:var(--accent);}
  .field-error{border-color:#dc3545!important;box-shadow:0 0 0 3px rgba(220,53,69,0.12)!important;background:#fff8f8!important;}
  .error-msg{display:none;color:#dc3545;font-size:12px;font-weight:600;margin-top:5px;padding:6px 10px;background:#fff0f0;border-radius:7px;border-left:3px solid #dc3545;}
  .error-msg.show{display:block;}

</style>

<div class="show-page">
  <div class="show-hero">
    <img src="<%= listing.image.url %>" alt="<%= listing.title %>"/>
    <div class="show-hero-overlay"></div>
    <div class="show-hero-info">
      <h2><%= listing.title %></h2>
      <span class="show-hero-loc"><i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %></span>
    </div>
  </div>

  <% if(currUser && listing.owner._id.equals(currUser._id)) { %>
    <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">Edit</a>
    <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Delete your listing?')">
      <button class="btn btn-danger">Delete</button>
    </form>
  <% } %>
  <% if(currUser && currUser.isAdmin && (!listing.owner._id.equals(currUser._id))) { %>
    <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Admin: Delete this listing?')">
      <button style="background:linear-gradient(135deg,#dc3545,#a71d2a);color:white;border:none;border-radius:8px;padding:9px 20px;font-weight:700;cursor:pointer;font-family:DM Sans,sans-serif;font-size:13px;">🗑️ Admin Delete</button>
    </form>
  <% } %>

  <div class="show-grid">
    <div>
      <div class="info-card">
        <div class="info-card-header"><span class="tag">✦ Listing Details</span><h3><%= listing.title %></h3></div>
        <div class="info-card-body">
          <div class="info-row"><i class="fa-solid fa-user"></i><div><div class="info-label">Hosted by</div><div class="info-val"><%= listing.owner.username %></div></div></div>
          <div class="info-row"><i class="fa-solid fa-align-left"></i><div><div class="info-label">Description</div><div class="info-val" style="font-weight:400;line-height:1.6"><%= listing.description %></div></div></div>
          <% if(listing.category) { %><div class="info-row"><i class="fa-solid fa-tag"></i><div><div class="info-label">Category</div><div class="info-val"><%= listing.category %></div></div></div><% } %>
          <div class="info-row"><i class="fa-solid fa-location-dot"></i><div><div class="info-label">Location</div><div class="info-val"><%= listing.location %>, <%= listing.country %></div></div></div>
          <div class="info-row"><i class="fa-solid fa-indian-rupee-sign"></i><div><div class="info-label">Price</div><div class="info-price">₹<%= listing.price.toLocaleString("en-IN") %> <span class="info-price-night">/ night</span></div></div></div>
        </div>
      </div>

      <div class="reviews-section">
        <% if(currUser) { %>
          <div class="section-head">Leave a Review</div>
          <div class="review-form-card">
            <form action="/listings/<%= listing.id %>/reviews" method="POST" novalidate class="needs-validation">
              <label class="bc-label">Rating</label>
              <fieldset class="starability-slot mb-3">
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating."/>
                <input type="radio" id="first-rate1" name="review[rating]" value="1"/><label for="first-rate1" title="Terrible">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2"/><label for="first-rate2" title="Not good">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3"/><label for="first-rate3" title="Average">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4"/><label for="first-rate4" title="Very good">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5"/><label for="first-rate5" title="Amazing">5 stars</label>
              </fieldset>
              <label class="bc-label">Comment</label>
              <textarea name="review[comment]" class="review-textarea" required placeholder="Share your experience…"></textarea>
              <div class="invalid-feedback">Please add a comment.</div>
              <button type="submit" class="btn-review"><i class="fa-solid fa-paper-plane me-1"></i> Submit Review</button>
            </form>
          </div>
        <% } %>
        <% if(listing.reviews.length > 0) { %>
          <div class="section-head">All Reviews</div>
          <% for(review of listing.reviews) { %>
            <div class="review-card">
              <div class="review-author">@<%= review.author.username %></div>
              <% if(review.rating) { %><p class="starability-result" data-rating="<%= review.rating %>" style="margin:4px 0 6px"></p><% } %>
              <div class="review-comment"><%= review.comment %></div>
              <% if(currUser && review.author && review.author._id.equals(currUser._id)) { %>
                <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                  <button type="submit" class="btn-del-review"><i class="fa-solid fa-trash me-1"></i> Delete</button>
                </form>
              <% } %>
            </div>
          <% } %>
        <% } %>
      </div>

      <div class="map-section mt-4">
        <div class="section-head">Where you'll be</div>
        <div style="border-radius:16px;overflow:hidden;box-shadow:0 8px 30px rgba(0,0,0,0.15);">
<iframe
  width="100%"
  height="380"
  style="border:0;"
  loading="lazy"
  allowfullscreen
  src="https://maps.google.com/maps?q=<%= encodeURIComponent(listing.location + ', ' + listing.country) %>&t=m&z=13&ie=UTF8&iwloc=&output=embed">
</iframe>
</div>
        <div class="mt-3">
          <a href="https://www.google.com/maps/search/?q=<%= encodeURIComponent(listing.location + ' ' + listing.country) %>" target="_blank" class="btn-gmaps"><i class="fa-solid fa-location-arrow"></i> Open in Google Maps</a>
        </div>
      </div>
    </div>

<style>
.complaint-section { margin-top: 28px; }
.complaint-card {
  background: var(--white); border-radius: var(--radius);
  box-shadow: var(--shadow); padding: 22px;
  border-left: 3px solid #dc3545;
}
.complaint-card .section-head { color: #dc3545; }
.complaint-card .section-head::after { background: linear-gradient(90deg, rgba(220,53,69,0.3), transparent); }
.complaint-input {
  width: 100%; padding: 10px 14px; border: 2px solid var(--border);
  border-radius: 10px; font-family: 'DM Sans', sans-serif;
  font-size: 14px; color: var(--ink); background: var(--cream);
  outline: none; transition: border-color .2s; margin-bottom: 12px;
}
.complaint-input:focus { border-color: #dc3545; background: white; }
.complaint-textarea {
  width: 100%; padding: 11px 14px; border: 2px solid var(--border);
  border-radius: 10px; font-family: 'DM Sans', sans-serif;
  font-size: 14px; resize: vertical; min-height: 80px;
  outline: none; background: var(--cream); transition: border-color .2s;
  margin-bottom: 12px;
}
.complaint-textarea:focus { border-color: #dc3545; background: white; }
.btn-complaint {
  padding: 10px 22px; background: transparent;
  border: 2px solid #dc3545; color: #dc3545;
  border-radius: 10px; font-family: 'DM Sans', sans-serif;
  font-size: 13px; font-weight: 600; cursor: pointer; transition: all .2s;
}
.btn-complaint:hover { background: #dc3545; color: white; }
</style>

<div class="complaint-section">
  <% if(currUser) { %>
    <div class="section-head" style="font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:600;color:#dc3545;margin-bottom:14px;display:flex;align-items:center;gap:10px;">
      Report a Problem
      <span style="flex:1;height:1px;background:linear-gradient(90deg,rgba(220,53,69,0.3),transparent);display:block;"></span>
    </div>
    <div class="complaint-card">
      <p style="font-size:13px;color:var(--muted);margin-bottom:16px;line-height:1.6;">
        Something wrong with this listing? Let us know — our team will review it within 24 hours.
      </p>
      <form action="/listings/<%= listing._id %>/complaint" method="POST">
        <input type="text" name="name" class="complaint-input"
               placeholder="Your name" value="<%= currUser.username %>" required/>
        <input type="email" name="email" class="complaint-input"
               placeholder="Your email" value="<%= currUser.email || '' %>" required/>
        <input type="text" name="subject" class="complaint-input"
               placeholder="Subject — e.g. Fake listing, Misleading photos…" required/>
        <textarea name="message" class="complaint-textarea" required
                  placeholder="Describe the issue in detail…"></textarea>
        <button type="submit" class="btn-complaint">
          <i class="fa-solid fa-flag me-1"></i> Submit Complaint
        </button>
      </form>
    </div>
  <% } %>
</div>


    <div>
      <div class="booking-card">
        <div class="booking-card-header"><span class="tag">✦ Reserve Your Stay</span><h4><%= listing.title %></h4></div>
        <div class="booking-card-body">
          <% if(currUser) { %>
            <form action="/booking/<%= listing._id %>" method="POST" id="bookingForm" novalidate>
              <div class="bc-stack">
                <div>
                  <label class="bc-label">Check-in</label>
                  <input type="date" class="bc-input" id="checkIn" name="checkIn" required/>
                  <div class="error-msg" id="checkInError">⚠ Please select a check-in date</div>
                </div>
                <div>
                  <label class="bc-label">Check-out</label>
                  <input type="date" class="bc-input" id="checkOut" name="checkOut" required/>
                  <div class="error-msg" id="checkOutError">⚠ Please select a check-out date</div>
                </div>
              </div>
              <div class="bc-field">
                <label class="bc-label">Guests</label>
                <select class="bc-select" id="guests" name="guests" required>
                  <option value="" disabled selected>Select guests</option>
                  <option value="1">1 Guest</option><option value="2">2 Guests</option>
                  <option value="3">3 Guests</option><option value="4">4 Guests</option>
                  <option value="5">5 Guests</option><option value="6">6+ Guests</option>
                </select>
                <div class="error-msg" id="guestsError">⚠ Please select number of guests</div>
              </div>
              <div class="price-preview" id="pricePreview">
                <div class="pp-row"><span>₹<%= listing.price.toLocaleString("en-IN") %> x <span id="nightCount">0</span> nights</span></div>
                <div class="pp-total"><span>Total</span><span>Rs.<span id="totalPreview">0</span></span></div>
              </div>
              <button type="submit" class="btn-book"><i class="fa-solid fa-lock"></i> Book Now</button>
            </form>
          <% } else { %>
            <p style="font-size:13px;color:var(--muted);margin-bottom:16px;text-align:center;">Log in to book this stay</p>
            <a href="/login" class="btn-login-book"><i class="fa-solid fa-right-to-bracket me-2"></i>Login to Book</a>
          <% } %>
          <% if(currUser && !listing.owner._id.equals(currUser._id)) { %>
            <div style="margin-top:14px;border-top:1px solid var(--border);padding-top:16px;">
              <p style="font-size:12px;color:var(--muted);margin-bottom:10px;text-align:center;">Have a question before booking?</p>
              <button id="openContactModal" style="width:100%;padding:12px;background:transparent;border:2px solid var(--accent);color:var(--accent);border-radius:10px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;cursor:pointer;transition:all .2s;">
                <i class="fa-solid fa-envelope me-2"></i> Contact Owner
              </button>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Contact Owner Modal -->
<div id="contactModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:9999;align-items:center;justify-content:center;padding:16px;">
  <div style="background:white;border-radius:16px;width:100%;max-width:480px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,0.3);">
    <div style="background:#1a1a2e;padding:20px 24px;display:flex;justify-content:space-between;align-items:center;">
      <div>
        <p style="margin:0 0 2px;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:#d4a843;">✦ Wanderlust</p>
        <h4 style="margin:0;color:white;font-family:'Playfair Display',serif;font-size:1.1rem;">Contact Owner</h4>
      </div>
      <button id="closeContactModal" style="background:transparent;border:none;color:rgba(255,255,255,0.6);font-size:20px;cursor:pointer;line-height:1;">✕</button>
    </div>
    <div style="padding:24px;">
      <p style="font-size:13px;color:#6b6b7b;margin-bottom:16px;">Your message will be sent to <strong><%= listing.owner.username %></strong>. They can reply to your email <strong><%= currUser ? currUser.email : '' %></strong>.</p>
      <form action="/listings/<%= listing._id %>/contact" method="POST">
        <label style="font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:#6b6b7b;display:block;margin-bottom:6px;">Your Message</label>
        <textarea name="message" required rows="4" placeholder="Hi! I'm interested in your listing..." style="width:100%;padding:12px 14px;border:2px solid #e0d8cc;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:14px;resize:vertical;outline:none;background:#faf7f2;box-sizing:border-box;"></textarea>
        <button type="submit" style="margin-top:12px;width:100%;padding:13px;background:linear-gradient(135deg,#c9783a,#a85e28);color:white;border:none;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:700;cursor:pointer;">
          <i class="fa-solid fa-paper-plane me-2"></i> Send Message
        </button>
      </form>
    </div>
  </div>
</div>



<link href="https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.css" rel="stylesheet"/>
<script src="https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.js"></script>
<script src="/js/map.js"></script>



<script>
document.addEventListener("DOMContentLoaded", function () {

  // ================= BOOKING VALIDATION =================
  const form = document.getElementById("bookingForm");

  if (form) {
    const checkIn = document.getElementById("checkIn");
    const checkOut = document.getElementById("checkOut");
    const guests = document.getElementById("guests");

    form.addEventListener("submit", function (e) {
      let valid = true;

      ["checkIn","checkOut","guests"].forEach(id => {
        document.getElementById(id).classList.remove("field-error");
      });

      ["checkInError","checkOutError","guestsError"].forEach(id => {
        document.getElementById(id).classList.remove("show");
      });

      if (!checkIn.value) {
        checkIn.classList.add("field-error");
        document.getElementById("checkInError").classList.add("show");
        valid = false;
      }

      if (!checkOut.value) {
        checkOut.classList.add("field-error");
        document.getElementById("checkOutError").classList.add("show");
        valid = false;
      }

      if (checkIn.value && checkOut.value) {
        if (new Date(checkOut.value) <= new Date(checkIn.value)) {
          checkOut.classList.add("field-error");
          const msg = document.getElementById("checkOutError");
          msg.innerText = "⚠ Check-out must be after check-in";
          msg.classList.add("show");
          valid = false;
        }
      }

      if (!guests.value) {
        guests.classList.add("field-error");
        document.getElementById("guestsError").classList.add("show");
        valid = false;
      }

      if (!valid) {
        e.preventDefault();
      }
    });
  }

  // ================= CONTACT MODAL =================
  const modal = document.getElementById("contactModal");
  const openBtn = document.getElementById("openContactModal");
  const closeBtn = document.getElementById("closeContactModal");

  if (modal) {
    if (openBtn) openBtn.onclick = () => modal.style.display = "flex";
    if (closeBtn) closeBtn.onclick = () => modal.style.display = "none";

    modal.onclick = (e) => {
      if (e.target === modal) modal.style.display = "none";
    };
  }

});
</script>
