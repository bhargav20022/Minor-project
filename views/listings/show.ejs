<% layout("/layouts/boilerplate") %>

<script>
  const mapToken = "<%= process.env.MAP_TOKEN %>";
  const listing = '"<%- JSON.stringify(listing) %>";
</script>

<style>
  #map {
    height: 400px;
    width: 100%;
    border-radius: 12px;
  }
  .show-card {
    border: none !important;
  }
  .show-img {
    height: 40vh;
    object-fit: cover;
    border-radius: 15px;
  }
  .btns {
    display: flex;
    gap: 1rem;
  }
</style>

<div class="row mt-3">
  <div class="col-lg-8 col-md-10 col-sm-12 mx-auto">
    
    <h3><%= listing.title %></h3>

    <div class="card show-card listing-card">
      <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image">
      <div class="card-body px-0">
        <p class="card-text">Owned by <i><%= listing.owner.username %></i></p>
        <p class="card-text"><%= listing.description %></p>
        <p class="card-text">
            <b>Price:</b> &#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %> / night
        </p>
        <p class="card-text"><b>Location:</b> <%= listing.location %>, <%= listing.country %></p>
      </div>
    </div>

    <% if(currUser && listing.owner._id.equals(currUser._id)) { %>
      <div class="btns mb-4">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark edit-btn px-4">Edit</a>
        <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
          <button class="btn btn-danger">Delete Listing</button>
        </form>
      </div>
    <% } %>

    <hr />

    <div class="mb-3">
      <% if(currUser) { %>
        <h4>Leave a Review</h4>
        <form action="/listings/<%= listing.id %>/reviews" method="POST" novalidate class="needs-validation">
          <div class="mb-3 mt-3">
            <label for="rating" class="form-label">Rating</label>
            <fieldset class="starability-slot">
              <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1" title="Terrible">1 star</label>
              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3" title="Average">3 stars</label>
              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input type="radio" id="first-rate5" name="review[rating]" value="5" />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
          </div>
          <div class="mb-3">
            <label for="comment" class="form-label">Comments</label>
            <textarea name="review[comment]" id="comment" cols="30" rows="4" class="form-control" required></textarea>
            <div class="invalid-feedback">Please provide a comment for the review.</div>
          </div>
          <button class="btn btn-outline-dark">Submit Review</button>
        </form>
        <hr />
      <% } %>

      <% if(listing.reviews.length > 0) { %>
        <h4 class="mb-3">All Reviews</h4>
        <div class="row">
          <% for(review of listing.reviews) { %>
            <div class="card col-md-5 ms-3 mb-3 p-3">
              <div class="card-body">
                <h5 class="card-title">@<%= review.author.username %></h5>
                <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
                <p class="card-text"><%= review.comment %></p>
                <% if(currUser && review.author._id.equals(currUser._id)) { %>
                  <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                    <button class="btn btn-sm btn-dark">Delete</button>
                  </form>
                <% } %>
              </div>
            </div>
          <% } %>
        </div>
        <hr />
      <% } %>
    </div>

    <div class="mb-4">
      <h3>Where you'll be</h3>
      <div id="map"></div>
    </div>

    <hr />

    <% if(currUser) { %>
    <div class="mb-5">
      <div class="card shadow-sm border-0 mx-auto" style="border-radius:16px; overflow:hidden; max-width: 500px;">
        
        <div style="background:#1a1a2e; padding:20px 28px;">
          <p style="margin:0 0 2px; font-size:11px; letter-spacing:2px; text-transform:uppercase; color:#d4a843;">✦ Quick Booking</p>
          <h5 style="margin:0; color:#fff; font-family:'serif'; font-size:20px;"><%= listing.title %></h5>
        </div>

        <div class="card-body p-4">
          <form action="/booking/<%= listing._id %>" method="POST" id="bookingForm" novalidate>
            
            <div class="row g-3 mb-3">
              <div class="col-6">
                <label for="checkIn" class="form-label fw-semibold" style="font-size:12px; color:#6b6b7b;">CHECK-IN</label>
                <input type="date" class="form-control" id="checkIn" name="checkIn" required style="border-radius:10px; background:#faf7f2;">
              </div>
              <div class="col-6">
                <label for="checkOut" class="form-label fw-semibold" style="font-size:12px; color:#6b6b7b;">CHECK-OUT</label>
                <input type="date" class="form-control" id="checkOut" name="checkOut" required style="border-radius:10px; background:#faf7f2;">
              </div>
            </div>

            <div class="mb-3">
              <label for="guests" class="form-label fw-semibold" style="font-size:12px; color:#6b6b7b;">GUESTS</label>
              <select class="form-select" id="guests" name="guests" required style="border-radius:10px; background:#faf7f2;">
                <option value="" disabled selected>Select number of guests</option>
                <option value="1">1 Guest</option>
                <option value="2">2 Guests</option>
                <option value="3">3 Guests</option>
                <option value="4">4 Guests</option>
                <option value="5">5 Guests</option>
              </select>
            </div>

            <div id="pricePreview" style="display:none; background:#faf7f2; border:1px solid #e0d8cc; border-radius:10px; padding:14px 18px; margin-bottom:16px;">
              <div class="d-flex justify-content-between align-items-center">
                <span style="font-size:13px; color:#6b6b7b;">
                  &#8377;<%= listing.price.toLocaleString("en-IN") %> &times; <span id="nightCount">0</span> nights
                </span>
                <strong style="font-size:16px; color:#1a1a2e;">
                  &#8377;<span id="totalPreview">0</span>
                </strong>
              </div>
            </div>

            <button type="submit" class="btn w-100 fw-semibold" style="background:linear-gradient(135deg,#c9783a,#a85e28); color:white; border-radius:10px; padding:13px; border:none;">
              <i class="fa-solid fa-lock me-2"></i> Book Now
            </button>
          </form>
        </div>
      </div>
    </div>
    <% } else { %>
      <div class="text-center mb-5">
        <a href="/login" class="btn btn-success px-5">Login to Book Now</a>
      </div>
    <% } %>

  </div>
</div>

<script src="/js/map.js"></script> <script>
  // Logic for Price Calculation and Date Validation
  const pricePerNight = <%= listing.price %>;
  const today = new Date().toISOString().split('T')[0];
  
  document.getElementById('checkIn').min = today;
  document.getElementById('checkOut').min = today;

  const ciInput = document.getElementById('checkIn');
  const coInput = document.getElementById('checkOut');

  function updatePreview() {
    const ci = ciInput.value;
    const co = coInput.value;

    if (ci) {
      const nextDay = new Date(ci);
      nextDay.setDate(nextDay.getDate() + 1);
      coInput.min = nextDay.toISOString().split('T')[0];
    }

    if (ci && co) {
      const nights = Math.round((new Date(co) - new Date(ci)) / (1000 * 60 * 60 * 24));
      if (nights > 0) {
        document.getElementById('nightCount').textContent = nights;
        document.getElementById('totalPreview').textContent = (pricePerNight * nights).toLocaleString('en-IN');
        document.getElementById('pricePreview').style.display = 'block';
      } else {
        document.getElementById('pricePreview').style.display = 'none';
      }
    }
  }

  ciInput.addEventListener('change', updatePreview);
  coInput.addEventListener('change', updatePreview);

  // Map Initialization (Direct logic if /js/map.js is not present)
  mapboxgl.accessToken = mapToken;
  const map = new mapboxgl.Map({
    container: 'map',
    style: 'mapbox://styles/mapbox/streets-v12',
    center: listing.geometry.coordinates,
    zoom: 9
  });

  new mapboxgl.Marker({ color: "red" })
    .setLngLat(listing.geometry.coordinates)
    .setPopup(new mapboxgl.Popup({offset: 25}).setHTML(`<h4>${listing.title}</h4><p>Exact location provided after booking</p>`))
    .addTo(map);
</script>
