<!-- ══════════════════════════════════════════════════
     SCRIPTS
══════════════════════════════════════════════════ -->
<script>
/* ── Server data (unchanged) ── */
const ALL_LISTINGS = <%- JSON.stringify(allListings.map(l => ({
  _id: l._id,
  title: l.title,
  location: l.location,
  country: l.country,
  price: l.price,
  image: l.image
}))) %>;

/* ── Stats ── */
(function(){
  const cities    = new Set(ALL_LISTINGS.map(l=>(l.location||'').trim()).filter(Boolean));
  const countries = new Set(ALL_LISTINGS.map(l=>(l.country||'').trim()).filter(Boolean));
  document.getElementById('statTotal').innerHTML     = `<span>${ALL_LISTINGS.length}</span>`;
  document.getElementById('statCities').innerHTML    = `<span>${cities.size}</span>`;
  document.getElementById('statCountries').innerHTML = `<span>${countries.size}</span>`;
  document.getElementById('listingCount').textContent = `${ALL_LISTINGS.length} places`;
})();

/* ═══════════════════════════════════════════
   🎰 DESTINATION ROULETTE
═══════════════════════════════════════════ */
let rouletteRunning = false;

function spinRoulette() {
  if (rouletteRunning || ALL_LISTINGS.length === 0) return;
  rouletteRunning = true;

  const btn    = document.getElementById('spinBtn');
  const label  = document.getElementById('spinLabel');
  const icon   = document.getElementById('spinIcon');
  const reels  = ['reel1','reel2','reel3'].map(id=>document.getElementById(id));
  const card   = document.getElementById('rouletteCard');
  const ph     = document.getElementById('roulettePlaceholder');

  btn.disabled = true;
  icon.style.animation = 'spinIcon .5s linear infinite';

  // Reset card
  card.classList.remove('revealed');

  const chars = ['🌍','🏖️','🏔️','🌿','🏰','💎','🌴','🕌','🌆','🎭','🗼','🌊','🏕️','🦁','🌺'];
  const picked = ALL_LISTINGS[Math.floor(Math.random() * ALL_LISTINGS.length)];

  // Spin all reels
  const intervals = reels.map(reel =>
    setInterval(() => {
      reel.textContent = chars[Math.floor(Math.random() * chars.length)];
      reel.style.color = ['var(--gold)','var(--accent)','#fff'][Math.floor(Math.random()*3)];
    }, 80)
  );

  // Stop reel 1
  setTimeout(() => {
    clearInterval(intervals[0]);
    reels[0].textContent = getEmoji(picked.location);
    reels[0].style.color = 'var(--gold)';
  }, 700);

  // Stop reel 2
  setTimeout(() => {
    clearInterval(intervals[1]);
    reels[1].textContent = picked.country ? picked.country[0] : '★';
    reels[1].style.color = 'var(--accent)';
  }, 1100);

  // Stop reel 3 + reveal card
  setTimeout(() => {
    clearInterval(intervals[2]);
    reels[2].textContent = '★';
    reels[2].style.color = 'var(--gold)';

    // Populate card
    document.getElementById('rrcImg').src              = picked.image?.url || '';
    document.getElementById('rrcImg').alt              = picked.title;
    document.getElementById('rrcTitle').textContent    = picked.title;
    document.getElementById('rrcLocationText').textContent = `${picked.location}, ${picked.country}`;
    document.getElementById('rrcPrice').textContent    = picked.price ? picked.price.toLocaleString('en-IN') : 'N/A';
    document.getElementById('rrcLink').href            = `/listings/${picked._id}`;
    document.getElementById('rrcBadge').textContent    = `${getEmoji(picked.location)} Surprise Pick!`;

    ph.style.display   = 'none';
    card.style.display = 'block';
    requestAnimationFrame(()=>requestAnimationFrame(()=>card.classList.add('revealed')));

    icon.style.animation = '';
    btn.disabled  = false;
    label.textContent = 'Spin Again!';
    rouletteRunning   = false;
  }, 1600);
}

/* ═══════════════════════════════════════════
   🌈 MOOD DISCOVERY
═══════════════════════════════════════════ */
const MOOD_KEYWORDS = {
  adventure: ['manali','shimla','mountain','hill','trek','camp','forest','valley','leh','ooty','munnar','coorg','rishikesh','auli','spiti'],
  romance:   ['goa','beach','sea','ocean','lake','resort','villa','andaman','udaipur','alleppey','pondicherry','sunset','cozy'],
  peace:     ['kerala','ooty','coorg','garden','farm','nature','retreat','lonavala','mussoorie','nainital','valley','mysore','serene'],
  culture:   ['jaipur','delhi','agra','varanasi','kolkata','rajasthan','heritage','fort','palace','temple','city','historic','mumbai','chennai','hyderabad','banaras']
};
let activeMood = null;

function setMood(el, mood) {
  if (activeMood === mood) { clearMood(); return; }
  activeMood = mood;
  document.querySelectorAll('.mood-card').forEach(c=>c.classList.remove('active'));
  el.classList.add('active');

  const keywords = MOOD_KEYWORDS[mood] || [];
  const cards    = document.querySelectorAll('#allListingsGrid .listing-link');
  let count = 0;

  cards.forEach(c => {
    const loc   = (c.dataset.location||'').toLowerCase();
    const cntry = (c.dataset.country ||'').toLowerCase();
    const ttl   = (c.dataset.title   ||'').toLowerCase();
    const match = keywords.some(k => loc.includes(k)||cntry.includes(k)||ttl.includes(k));
    c.classList.toggle('hidden', !match);
    if (match) count++;
  });

  if (count === 0) {
    cards.forEach(c=>c.classList.remove('hidden'));
    count = cards.length;
  }

  const names = { adventure:'Adventure 🧗', romance:'Romance 🌹', peace:'Peace 🌿', culture:'Culture 🏛️' };
  document.getElementById('moodFilterLabel').textContent  = names[mood];
  document.getElementById('moodFilterCount').textContent  = count;
  document.getElementById('listingCount').textContent     = `${count} places`;
  document.getElementById('moodFilterBar').classList.add('show');
  document.getElementById('allListingsGrid').scrollIntoView({behavior:'smooth',block:'start'});
}

function clearMood() {
  activeMood = null;
  document.querySelectorAll('.mood-card').forEach(c=>c.classList.remove('active'));
  document.querySelectorAll('#allListingsGrid .listing-link').forEach(c=>c.classList.remove('hidden'));
  document.getElementById('moodFilterBar').classList.remove('show');
  document.getElementById('listingCount').textContent = `${ALL_LISTINGS.length} places`;
}

/* ═══════════════════════════════════════════
   ✨ HERO PARTICLES
═══════════════════════════════════════════ */
(function(){
  const canvas = document.getElementById('heroCanvas');
  const ctx    = canvas.getContext('2d');
  let W, H, particles = [];

  function resize() { W = canvas.width = canvas.offsetWidth; H = canvas.height = canvas.offsetHeight; }

  class Particle {
    constructor() { this.reset(); }
    reset() {
      this.x  = Math.random()*W; this.y = Math.random()*H;
      this.r  = Math.random()*1.6+0.3;
      this.vx = (Math.random()-.5)*.3; this.vy = (Math.random()-.5)*.3;
      this.a  = Math.random()*.6+.1;
      this.color = Math.random()>.6 ? '#d4a843' : '#c9783a';
    }
    update() {
      this.x+=this.vx; this.y+=this.vy;
      if(this.x<0||this.x>W||this.y<0||this.y>H) this.reset();
    }
    draw() {
      ctx.save(); ctx.globalAlpha=this.a; ctx.fillStyle=this.color;
      ctx.beginPath(); ctx.arc(this.x,this.y,this.r,0,Math.PI*2); ctx.fill(); ctx.restore();
    }
  }

  function init() { resize(); particles = Array.from({length:80},()=>new Particle()); }
  function loop() { ctx.clearRect(0,0,W,H); particles.forEach(p=>{p.update();p.draw();}); requestAnimationFrame(loop); }
  window.addEventListener('resize',resize);
  init(); loop();
})();

/* ═══════════════════════════════════════════
   AUTOCOMPLETE
═══════════════════════════════════════════ */
const input      = document.getElementById('citySearchInput');
const dropdown   = document.getElementById('autocompleteDropdown');
const sugList    = document.getElementById('suggestionsList');
const noSug      = document.getElementById('noSuggestion');
let highlightIdx = -1, currentSuggestions = [];

const cityEmojis = {
  'goa':'🏖️','mumbai':'🌆','delhi':'🕌','jaipur':'🏰','manali':'🏔️',
  'kerala':'🌴','udaipur':'💎','ooty':'🌿','shimla':'❄️','agra':'🕍',
  'pune':'🏙️','bangalore':'💻','hyderabad':'🍛','kolkata':'🎨',
  'paris':'🗼','london':'🎡','new york':'🗽','dubai':'🌇','bali':'🌺',
  'default':'📍'
};
function getEmoji(city) {
  const key=(city||'').toLowerCase();
  for(const k in cityEmojis) if(key.includes(k)) return cityEmojis[k];
  return cityEmojis['default'];
}
function getCityMap(query) {
  const map={};
  ALL_LISTINGS.forEach(l=>{
    const city=(l.location||'').trim();
    if(!city||!city.toLowerCase().includes(query.toLowerCase())) return;
    if(!map[city]) map[city]={city,country:l.country,count:0};
    map[city].count++;
  });
  return Object.values(map).sort((a,b)=>b.count-a.count);
}
function highlightMatch(text,query) {
  const idx=text.toLowerCase().indexOf(query.toLowerCase());
  if(idx===-1) return text;
  return text.slice(0,idx)+`<strong style="color:var(--accent)">${text.slice(idx,idx+query.length)}</strong>`+text.slice(idx+query.length);
}
input.addEventListener('input',()=>{
  const q=input.value.trim(); highlightIdx=-1;
  if(q.length<1){closeDropdown();return;}
  currentSuggestions=getCityMap(q); renderDropdown(currentSuggestions,q);
});
function renderDropdown(cities,q){
  sugList.innerHTML='';
  if(!cities.length){noSug.style.display='block';dropdown.classList.add('open');return;}
  noSug.style.display='none';
  cities.slice(0,8).forEach(c=>{
    const item=document.createElement('div'); item.className='suggestion-item';
    item.innerHTML=`<div class="suggestion-icon">${getEmoji(c.city)}</div><div class="suggestion-text"><div class="city-name">${highlightMatch(c.city,q)}</div><div class="city-sub">${c.country||''}</div></div><div class="suggestion-count">${c.count} stay${c.count>1?'s':''}</div>`;
    item.addEventListener('mousedown',()=>selectCity(c.city));
    sugList.appendChild(item);
  });
  dropdown.classList.add('open');
}
input.addEventListener('keydown',e=>{
  const items=sugList.querySelectorAll('.suggestion-item');
  if(e.key==='ArrowDown'){highlightIdx=Math.min(highlightIdx+1,items.length-1);updateHighlight(items);}
  else if(e.key==='ArrowUp'){highlightIdx=Math.max(highlightIdx-1,-1);updateHighlight(items);}
  else if(e.key==='Enter'){if(highlightIdx>=0&&currentSuggestions[highlightIdx])selectCity(currentSuggestions[highlightIdx].city);else triggerCitySearch();}
  else if(e.key==='Escape')closeDropdown();
});
function updateHighlight(items){items.forEach((el,i)=>el.classList.toggle('highlighted',i===highlightIdx));}
function closeDropdown(){dropdown.classList.remove('open');sugList.innerHTML='';noSug.style.display='none';}
document.addEventListener('click',e=>{if(!e.target.closest('.search-box'))closeDropdown();});
function selectCity(city){input.value=city;closeDropdown();showCityResults(city);}
function quickSearch(city){input.value=city;showCityResults(city);}
function triggerCitySearch(){const city=input.value.trim();if(city)showCityResults(city);}

function showCityResults(city){
  closeDropdown();
  const matched=ALL_LISTINGS.filter(l=>(l.location||'').toLowerCase().includes(city.toLowerCase())||(l.country||'').toLowerCase().includes(city.toLowerCase()));
  const section=document.getElementById('cityResultsSection');
  const container=document.getElementById('cityCardsContainer');
  document.getElementById('cityResultsTitle').textContent=city;
  section.style.display='block';
  if(!matched.length){
    container.innerHTML=`<div class="no-city-results"><i class="fa-solid fa-map-location-dot"></i><p>No stays found in <strong>${city}</strong>.</p></div>`;
    section.scrollIntoView({behavior:'smooth',block:'start'}); return;
  }
  container.innerHTML=`<div class="city-cards-grid">${matched.map(l=>`
    <a href="/listings/${l._id}" class="city-listing-card">
      <div class="city-card-img-wrap"><img src="${l.image?.url||''}" alt="${l.title}" loading="lazy"/><span class="city-card-badge">${getEmoji(l.location)} ${l.location}</span></div>
      <div class="city-card-body">
        <div class="title">${l.title}</div>
        <div class="location"><i class="fa-solid fa-location-dot"></i> ${l.location}, ${l.country}</div>
        <div class="price">₹${l.price?l.price.toLocaleString('en-IN'):'N/A'}<span class="per-night">/ night</span></div>
      </div>
    </a>`).join('')}</div>`;
  section.scrollIntoView({behavior:'smooth',block:'start'});
}
function clearSearch(){input.value='';document.getElementById('cityResultsSection').style.display='none';}

/* ── Tax ── */
document.getElementById('flexSwitchCheckDefault').addEventListener('click',function(){
  document.querySelectorAll('.tax-info').forEach(el=>{el.style.display=(el.style.display!=='inline')?'inline':'none';});
});

/* ── Filters ── */
document.querySelectorAll('#filters .filter').forEach(btn=>{
  btn.addEventListener('click',function(){
    document.querySelectorAll('#filters .filter').forEach(b=>b.classList.remove('active'));
    this.classList.add('active');
  });
});

/* ── Wishlist ── */
const wishlist=new Set(JSON.parse(localStorage.getItem('wl_wishlist')||'[]'));
function toggleWishlist(e,id){
  e.preventDefault();e.stopPropagation();
  const btn=e.currentTarget,icon=btn.querySelector('i');
  if(wishlist.has(id)){wishlist.delete(id);icon.className='fa-regular fa-heart';btn.classList.remove('liked');}
  else{wishlist.add(id);icon.className='fa-solid fa-heart';btn.classList.add('liked');btn.animate([{transform:'scale(1)'},{transform:'scale(1.4)'},{transform:'scale(1)'}],{duration:300,easing:'ease'});}
  localStorage.setItem('wl_wishlist',JSON.stringify([...wishlist]));
}
document.querySelectorAll('.wishlist-btn').forEach(btn=>{
  const id=btn.closest('.listing-link')?.dataset.id;
  if(id&&wishlist.has(id)){btn.querySelector('i').className='fa-solid fa-heart';btn.classList.add('liked');}
});

/* ── View ── */
function setView(mode){
  const grid=document.getElementById('allListingsGrid');
  document.getElementById('gridViewBtn').classList.toggle('active',mode==='grid');
  document.getElementById('listViewBtn').classList.toggle('active',mode==='list');
  grid.classList.toggle('list-view',mode==='list');
}

/* ── Sort ── */
function sortListings(){
  const val=document.getElementById('sortSelect').value;
  const grid=document.getElementById('allListingsGrid');
  const cards=[...grid.querySelectorAll('.listing-link')];
  cards.sort((a,b)=>{
    const dA=ALL_LISTINGS.find(l=>l._id==a.dataset.id);
    const dB=ALL_LISTINGS.find(l=>l._id==b.dataset.id);
    if(!dA||!dB) return 0;
    if(val==='price-asc')  return (dA.price||0)-(dB.price||0);
    if(val==='price-desc') return (dB.price||0)-(dA.price||0);
    if(val==='name-asc')   return (dA.title||'').localeCompare(dB.title||'');
    return 0;
  });
  cards.forEach(c=>grid.appendChild(c));
}
</script>
