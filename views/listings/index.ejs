<% layout("/layouts/boilerplate") %>

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet"/>

<style>
:root {
  --ink:          #1a1a2e;
  --cream:        #faf7f2;
  --sand:         #f0ebe0;
  --accent:       #c9783a;
  --accent-light: #f0dcc8;
  --gold:         #d4a843;
  --muted:        #7a7a8a;
  --border:       #e0d8cc;
  --white:        #ffffff;
  --radius:       16px;
}
*, *::before, *::after { box-sizing: border-box; }
body { background: #f5f1eb; }

/* ══ HERO ══ */
.hero-search-section {
  background: linear-gradient(135deg,#0c0c20 0%,#1c1440 50%,#0c0c20 100%);
  border-radius: 28px; padding: 60px 48px 52px;
  margin: 24px 0 0; position: relative; overflow: hidden;
}
.hero-search-section::before {
  content:''; position:absolute; inset:0;
  background:
    radial-gradient(ellipse 55% 65% at 12% 65%, rgba(201,120,58,.22) 0%, transparent 65%),
    radial-gradient(ellipse 40% 50% at 88% 18%, rgba(212,168,67,.14) 0%, transparent 65%),
    radial-gradient(ellipse 35% 45% at 55% 85%, rgba(80,60,160,.12) 0%, transparent 60%);
  pointer-events:none;
}
#heroCanvas { position:absolute; inset:0; width:100%; height:100%; pointer-events:none; z-index:0; opacity:.55; }
.hero-content { position:relative; z-index:1; text-align:center; }
.hero-eyebrow {
  display:inline-flex; align-items:center; gap:10px;
  font-size:10.5px; font-weight:600; letter-spacing:3px; text-transform:uppercase;
  color:var(--gold); margin-bottom:20px;
}
.hero-eyebrow::before,.hero-eyebrow::after { content:''; width:32px; height:1px; background:linear-gradient(90deg,transparent,var(--gold)); opacity:.6; }
.hero-eyebrow::after { background:linear-gradient(90deg,var(--gold),transparent); }
.hero-title { font-family:'Cormorant Garamond',serif; font-size:clamp(34px,5.5vw,58px); font-weight:600; color:#fff; line-height:1.13; margin-bottom:14px; letter-spacing:-.5px; }
.hero-title em { font-style:italic; color:var(--gold); }
.hero-subtitle { font-family:'DM Sans',sans-serif; font-size:15px; color:rgba(255,255,255,.42); margin-bottom:38px; font-weight:300; }
.search-box { max-width:590px; margin:0 auto; position:relative; }
.search-input-wrap {
  display:flex; align-items:center; background:rgba(255,255,255,.97); border-radius:60px;
  padding:6px 6px 6px 22px; box-shadow:0 10px 50px rgba(0,0,0,.35),0 0 0 1px rgba(255,255,255,.1); gap:10px;
}
.search-input-wrap i { color:var(--accent); font-size:17px; flex-shrink:0; }
#citySearchInput { flex:1; border:none; outline:none; font-family:'DM Sans',sans-serif; font-size:15.5px; color:var(--ink); background:transparent; padding:11px 0; }
#citySearchInput::placeholder { color:#b0a8a0; }
.search-btn {
  background:linear-gradient(135deg,var(--accent) 0%,#a85e28 100%);
  color:white; border:none; border-radius:50px; padding:13px 26px;
  font-family:'DM Sans',sans-serif; font-size:13.5px; font-weight:600;
  cursor:pointer; white-space:nowrap; transition:all .22s;
  flex-shrink:0; display:flex; align-items:center; gap:7px;
}
.search-btn:hover { transform:scale(1.04); box-shadow:0 6px 20px rgba(201,120,58,.55); }
.autocomplete-dropdown {
  position:absolute; top:calc(100% + 10px); left:0; right:0;
  background:white; border-radius:20px; box-shadow:0 20px 60px rgba(0,0,0,.18);
  overflow:hidden; display:none; z-index:999; border:1px solid var(--border); animation:dropDown .2s ease;
}
@keyframes dropDown { from{opacity:0;transform:translateY(-8px)} to{opacity:1;transform:translateY(0)} }
.autocomplete-dropdown.open { display:block; }
.dropdown-section-label { font-size:10px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:var(--muted); padding:14px 18px 6px; }
.suggestion-item { display:flex; align-items:center; gap:14px; padding:11px 18px; cursor:pointer; transition:background .15s; font-family:'DM Sans',sans-serif; }
.suggestion-item:hover,.suggestion-item.highlighted { background:var(--sand); }
.suggestion-icon { width:38px; height:38px; border-radius:10px; background:var(--accent-light); display:flex; align-items:center; justify-content:center; font-size:17px; flex-shrink:0; }
.suggestion-text .city-name { font-size:14px; font-weight:600; color:var(--ink); }
.suggestion-text .city-sub  { font-size:12px; color:var(--muted); }
.suggestion-count { font-size:11px; font-weight:600; background:var(--accent-light); color:var(--accent); padding:3px 10px; border-radius:20px; }
.dropdown-no-result { padding:20px 18px; text-align:center; font-size:13px; color:var(--muted); display:none; }
.popular-cities { display:flex; flex-wrap:wrap; gap:8px; justify-content:center; margin-top:24px; }
.city-pill {
  background:rgba(255,255,255,.09); border:1px solid rgba(255,255,255,.18);
  color:rgba(255,255,255,.78); font-family:'DM Sans',sans-serif;
  font-size:12px; font-weight:500; padding:7px 16px; border-radius:30px;
  cursor:pointer; transition:all .22s; backdrop-filter:blur(4px);
}
.city-pill:hover { background:rgba(201,120,58,.28); border-color:var(--accent); color:white; transform:translateY(-2px); box-shadow:0 4px 14px rgba(201,120,58,.3); }

/* ══ ROULETTE ══ */
.roulette-section {
  margin: 28px 0 36px;
  background: linear-gradient(135deg,#1a1a2e 0%,#2d2250 100%);
  border-radius: 28px; padding: 40px 44px 44px;
  position: relative; overflow: hidden; display: flex; align-items: center; gap: 48px;
}
.roulette-section::before {
  content:''; position:absolute; inset:0;
  background: radial-gradient(ellipse 50% 80% at 80% 50%, rgba(212,168,67,.12) 0%,transparent 65%), radial-gradient(ellipse 30% 40% at 10% 20%, rgba(201,120,58,.1) 0%,transparent 60%);
  pointer-events:none;
}
.roulette-section::after { content:''; position:absolute; inset:0; background-image: radial-gradient(rgba(255,255,255,.04) 1px, transparent 1px); background-size:22px 22px; pointer-events:none; }
.roulette-left { flex:1; position:relative; z-index:1; }
.roulette-eyebrow { display:inline-flex; align-items:center; gap:8px; font-size:10px; font-weight:700; letter-spacing:2.5px; text-transform:uppercase; color:var(--gold); margin-bottom:14px; background:rgba(212,168,67,.12); padding:5px 14px; border-radius:20px; border:1px solid rgba(212,168,67,.25); }
.roulette-title { font-family:'Cormorant Garamond',serif; font-size:clamp(26px,3.5vw,38px); font-weight:600; color:#fff; line-height:1.18; margin-bottom:12px; }
.roulette-title em { font-style:italic; color:var(--gold); }
.roulette-desc { font-family:'DM Sans',sans-serif; font-size:14px; color:rgba(255,255,255,.5); font-weight:300; margin-bottom:28px; line-height:1.6; max-width:380px; }
.slot-strip { display:flex; gap:10px; margin-bottom:22px; }
.slot-reel { width:48px; height:48px; background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.14); border-radius:12px; overflow:hidden; display:flex; align-items:center; justify-content:center; font-family:'Cormorant Garamond',serif; font-size:22px; font-weight:600; color:var(--gold); transition:color .1s; }
.spin-btn { display:inline-flex; align-items:center; gap:10px; background:linear-gradient(135deg,var(--gold),#b8882e); color:#1a1a2e; border:none; border-radius:50px; padding:16px 34px; font-family:'DM Sans',sans-serif; font-size:15px; font-weight:700; cursor:pointer; transition:all .25s; box-shadow:0 6px 28px rgba(212,168,67,.4); position:relative; overflow:hidden; }
.spin-btn::after { content:''; position:absolute; inset:0; background:linear-gradient(135deg,rgba(255,255,255,.25),transparent); border-radius:inherit; opacity:0; transition:opacity .2s; }
.spin-btn:hover::after { opacity:1; }
.spin-btn:hover { transform:scale(1.05) translateY(-2px); box-shadow:0 10px 36px rgba(212,168,67,.55); }
.spin-btn:disabled { opacity:.7; transform:none; cursor:default; }
.spin-icon { font-size:18px; display:inline-block; }
@keyframes spinIcon { to { transform:rotate(360deg); } }
.roulette-right { flex-shrink:0; width:310px; position:relative; z-index:1; }
.rrc-placeholder { display:flex; flex-direction:column; align-items:center; justify-content:center; height:300px; background:rgba(255,255,255,.05); border-radius:22px; border:2px dashed rgba(255,255,255,.14); color:rgba(255,255,255,.3); font-family:'DM Sans',sans-serif; transition:all .3s; }
.rrc-placeholder i { font-size:40px; margin-bottom:14px; opacity:.5; }
.rrc-placeholder p { font-size:13px; font-weight:300; text-align:center; line-height:1.5; }
.roulette-result-card { background:white; border-radius:22px; overflow:hidden; box-shadow:0 20px 60px rgba(0,0,0,.45); transform:scale(.9) rotateY(15deg); opacity:0; transition:all .55s cubic-bezier(.34,1.56,.64,1); pointer-events:none; }
.roulette-result-card.revealed { transform:scale(1) rotateY(0deg); opacity:1; pointer-events:auto; }
.rrc-img-wrap { position:relative; }
.rrc-img { width:100%; height:185px; object-fit:cover; display:block; }
.rrc-overlay { position:absolute; top:0; left:0; right:0; height:185px; background:linear-gradient(to bottom,transparent 40%,rgba(0,0,0,.5) 100%); }
.rrc-badge { position:absolute; bottom:12px; left:12px; background:rgba(212,168,67,.92); color:#1a1a2e; font-family:'DM Sans',sans-serif; font-size:10px; font-weight:700; padding:4px 12px; border-radius:20px; letter-spacing:.5px; text-transform:uppercase; }
.rrc-body { padding:18px 20px 20px; }
.rrc-title { font-family:'Cormorant Garamond',serif; font-size:20px; font-weight:600; color:var(--ink); margin-bottom:6px; line-height:1.2; }
.rrc-location { font-size:12px; color:var(--muted); margin-bottom:14px; display:flex; align-items:center; gap:4px; }
.rrc-footer { display:flex; align-items:center; justify-content:space-between; }
.rrc-price { font-family:'Cormorant Garamond',serif; font-size:24px; font-weight:600; color:var(--accent); }
.rrc-night { font-family:'DM Sans',sans-serif; font-size:11px; font-weight:400; color:var(--muted); }
.rrc-go-btn { background:var(--ink); color:white; border:none; border-radius:30px; padding:9px 20px; font-family:'DM Sans',sans-serif; font-size:12px; font-weight:600; cursor:pointer; text-decoration:none; display:inline-block; transition:all .2s; }
.rrc-go-btn:hover { background:var(--accent); color:white; transform:translateY(-1px); }

/* ══ CAB SECTION ══ */
.cab-section {
  margin: 0 0 36px;
  background: linear-gradient(135deg,#0f2027 0%,#203a43 50%,#2c5364 100%);
  border-radius: 28px; padding: 44px 48px;
  position: relative; overflow: hidden;
}
.cab-section::before {
  content:''; position:absolute; inset:0;
  background: radial-gradient(ellipse 40% 60% at 90% 50%, rgba(255,193,7,.1) 0%,transparent 65%), radial-gradient(ellipse 30% 40% at 10% 30%, rgba(0,188,212,.08) 0%,transparent 60%);
  pointer-events:none;
}
.cab-section::after { content:''; position:absolute; inset:0; background-image:radial-gradient(rgba(255,255,255,.03) 1px,transparent 1px); background-size:24px 24px; pointer-events:none; }
.cab-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:32px; flex-wrap:wrap; gap:16px; position:relative; z-index:1; }
.cab-eyebrow { display:inline-flex; align-items:center; gap:8px; font-size:10px; font-weight:700; letter-spacing:2.5px; text-transform:uppercase; color:#ffc107; margin-bottom:12px; background:rgba(255,193,7,.12); padding:5px 14px; border-radius:20px; border:1px solid rgba(255,193,7,.25); }
.cab-title { font-family:'Cormorant Garamond',serif; font-size:clamp(24px,3vw,34px); font-weight:600; color:#fff; line-height:1.2; margin:0 0 8px; }
.cab-title em { font-style:italic; color:#ffc107; }
.cab-subtitle { font-family:'DM Sans',sans-serif; font-size:14px; color:rgba(255,255,255,.45); font-weight:300; margin:0; }
.cab-trust-badges { display:flex; gap:10px; flex-wrap:wrap; }
.cab-badge { display:flex; align-items:center; gap:6px; background:rgba(255,255,255,.07); border:1px solid rgba(255,255,255,.14); border-radius:30px; padding:7px 14px; font-family:'DM Sans',sans-serif; font-size:11.5px; font-weight:500; color:rgba(255,255,255,.7); }
.cab-badge i { font-size:12px; color:#ffc107; }
.cab-cards { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; position:relative; z-index:1; }
@media(max-width:992px) { .cab-cards { grid-template-columns:repeat(2,1fr); } }
@media(max-width:576px)  { .cab-cards { grid-template-columns:1fr; } }
.cab-card { background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.12); border-radius:20px; padding:24px 20px 22px; cursor:pointer; transition:all .3s ease; position:relative; overflow:hidden; text-decoration:none; display:block; }
.cab-card::before { content:''; position:absolute; inset:0; opacity:0; transition:opacity .3s; border-radius:inherit; }
.cab-card-1::before { background:linear-gradient(135deg,rgba(255,193,7,.15),rgba(255,152,0,.1)); }
.cab-card-2::before { background:linear-gradient(135deg,rgba(0,188,212,.15),rgba(0,150,136,.1)); }
.cab-card-3::before { background:linear-gradient(135deg,rgba(156,39,176,.15),rgba(103,58,183,.1)); }
.cab-card-4::before { background:linear-gradient(135deg,rgba(76,175,80,.15),rgba(139,195,74,.1)); }
.cab-card:hover { transform:translateY(-6px); border-color:rgba(255,255,255,.28); box-shadow:0 16px 40px rgba(0,0,0,.35); }
.cab-card:hover::before { opacity:1; }
.cab-card-icon { width:54px; height:54px; border-radius:14px; margin-bottom:16px; display:flex; align-items:center; justify-content:center; font-size:24px; }
.cab-card-1 .cab-card-icon { background:rgba(255,193,7,.2); }
.cab-card-2 .cab-card-icon { background:rgba(0,188,212,.2); }
.cab-card-3 .cab-card-icon { background:rgba(156,39,176,.2); }
.cab-card-4 .cab-card-icon { background:rgba(76,175,80,.2); }
.cab-card-title { font-family:'DM Sans',sans-serif; font-size:15px; font-weight:600; color:#fff; margin-bottom:6px; }
.cab-card-desc { font-family:'DM Sans',sans-serif; font-size:12px; color:rgba(255,255,255,.45); line-height:1.5; margin-bottom:14px; }
.cab-card-price { font-family:'Cormorant Garamond',serif; font-size:20px; font-weight:600; color:#ffc107; }
.cab-card-price span { font-family:'DM Sans',sans-serif; font-size:11px; font-weight:400; color:rgba(255,255,255,.4); }
.cab-card-arrow { position:absolute; top:18px; right:18px; width:28px; height:28px; background:rgba(255,255,255,.08); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:11px; color:rgba(255,255,255,.4); transition:all .2s; }
.cab-card:hover .cab-card-arrow { background:rgba(255,193,7,.25); color:#ffc107; transform:translateX(2px); }

/* ══ CAB MODAL ══ */
.cab-overlay { position:fixed; inset:0; background:rgba(10,10,22,.72); backdrop-filter:blur(6px); z-index:1200; display:flex; align-items:center; justify-content:center; padding:16px; opacity:0; pointer-events:none; transition:opacity .3s ease; }
.cab-overlay.open { opacity:1; pointer-events:all; }
.cab-modal-box { background:var(--white); border-radius:28px; width:100%; max-width:560px; max-height:92vh; overflow-y:auto; box-shadow:0 32px 80px rgba(0,0,0,.45); transform:translateY(30px) scale(.97); transition:transform .35s cubic-bezier(.34,1.56,.64,1); scrollbar-width:none; }
.cab-modal-box::-webkit-scrollbar { display:none; }
.cab-overlay.open .cab-modal-box { transform:translateY(0) scale(1); }
.cab-modal-hdr { background:linear-gradient(135deg,#1a1a2e 0%,#2d2250 100%); padding:28px 28px 24px; border-radius:28px 28px 0 0; position:relative; overflow:hidden; }
.cab-modal-hdr::before { content:''; position:absolute; inset:0; background:radial-gradient(ellipse 60% 80% at 90% 20%,rgba(212,168,67,.15) 0%,transparent 65%); pointer-events:none; }
.cab-modal-x { position:absolute; top:18px; right:20px; width:34px; height:34px; background:rgba(255,255,255,.1); border:1px solid rgba(255,255,255,.15); border-radius:50%; color:rgba(255,255,255,.7); font-size:15px; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all .2s; z-index:1; }
.cab-modal-x:hover { background:rgba(255,255,255,.18); color:white; transform:rotate(90deg); }
.cab-modal-ey { font-size:10px; font-weight:700; letter-spacing:2.5px; text-transform:uppercase; color:var(--gold); margin-bottom:8px; font-family:'DM Sans',sans-serif; position:relative; z-index:1; }
.cab-modal-ttl { font-family:'Cormorant Garamond',serif; font-size:26px; font-weight:600; color:white; margin-bottom:6px; line-height:1.2; position:relative; z-index:1; }
.cab-modal-sub2 { font-family:'DM Sans',sans-serif; font-size:13px; color:rgba(255,255,255,.45); font-weight:300; position:relative; z-index:1; }
.cab-car-types { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; margin-bottom:20px; }
.cab-car-type { border:2px solid var(--border); background:var(--cream); border-radius:14px; padding:14px 10px 12px; cursor:pointer; text-align:center; transition:all .22s; }
.cab-car-type:hover { border-color:var(--accent); background:var(--accent-light); }
.cab-car-type.selected { border-color:var(--accent); background:var(--accent-light); box-shadow:0 0 0 3px rgba(201,120,58,.15); }
.cab-car-emoji { font-size:26px; display:block; margin-bottom:6px; }
.cab-car-name  { font-family:'DM Sans',sans-serif; font-size:12px; font-weight:700; color:var(--ink); }
.cab-car-seats { font-family:'DM Sans',sans-serif; font-size:11px; color:var(--muted); margin-top:2px; }
.cab-modal-bdy { padding:24px 28px 28px; }
.cab-field { margin-bottom:16px; }
.cab-lbl { display:block; font-size:11px; font-weight:700; letter-spacing:1.2px; text-transform:uppercase; color:var(--muted); margin-bottom:7px; font-family:'DM Sans',sans-serif; }
.cab-inp, .cab-sel { width:100%; padding:13px 16px; border:2px solid var(--border); border-radius:11px; font-family:'DM Sans',sans-serif; font-size:.93rem; color:var(--ink); background:var(--cream); outline:none; transition:border-color .2s,background .2s,box-shadow .2s; appearance:none; }
.cab-inp:focus, .cab-sel:focus { border-color:var(--accent); background:white; box-shadow:0 0 0 3px rgba(201,120,58,.1); }
.cab-inp::placeholder { color:rgba(107,107,123,.5); }
.cab-swap-wrap { display:flex; align-items:center; gap:10px; margin-bottom:10px; }
.cab-swap-line { flex:1; height:1px; background:var(--border); }
.cab-swap-btn { width:32px; height:32px; background:white; border:2px solid var(--border); border-radius:50%; display:flex; align-items:center; justify-content:center; cursor:pointer; font-size:13px; color:var(--accent); transition:all .2s; box-shadow:0 2px 8px rgba(0,0,0,.1); }
.cab-swap-btn:hover { border-color:var(--accent); transform:rotate(180deg); }
.cab-row2 { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
.cab-fare-est { display:none; background:linear-gradient(135deg,#1a1a2e,#2d2250); border-radius:14px; padding:16px 20px; margin-bottom:20px; animation:fadeUp .3s ease; }
.cab-fare-est.show { display:flex; align-items:center; justify-content:space-between; }
.cab-fare-lbl { font-family:'DM Sans',sans-serif; font-size:11px; font-weight:600; letter-spacing:1px; text-transform:uppercase; color:rgba(255,255,255,.45); margin-bottom:4px; }
.cab-fare-amt { font-family:'Cormorant Garamond',serif; font-size:26px; font-weight:600; color:var(--gold); }
.cab-fare-note { font-family:'DM Sans',sans-serif; font-size:11px; color:rgba(255,255,255,.35); }
.cab-fare-badge { background:rgba(212,168,67,.15); border:1px solid rgba(212,168,67,.3); border-radius:8px; padding:6px 12px; font-family:'DM Sans',sans-serif; font-size:11px; font-weight:600; color:var(--gold); text-align:center; }
.cab-submit-btn { width:100%; padding:16px; background:linear-gradient(135deg,var(--accent),#a85e28); color:white; border:none; border-radius:12px; font-family:'DM Sans',sans-serif; font-size:15px; font-weight:700; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:10px; transition:all .25s; box-shadow:0 4px 20px rgba(201,120,58,.35); }
.cab-submit-btn:hover { transform:translateY(-2px); box-shadow:0 8px 28px rgba(201,120,58,.45); }
.cab-success-box { display:none; padding:40px 28px; text-align:center; animation:fadeUp .4s ease; }
.cab-success-box.show { display:block; }
.cab-success-ico { width:80px; height:80px; background:rgba(45,122,79,.1); border:2px solid #2d7a4f; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 20px; font-size:32px; animation:popIn .5s cubic-bezier(.34,1.56,.64,1) both; }
@keyframes popIn { from{opacity:0;transform:scale(.5)} to{opacity:1;transform:scale(1)} }
.cab-success-ttl { font-family:'Cormorant Garamond',serif; font-size:26px; font-weight:600; color:var(--ink); margin-bottom:8px; }
.cab-success-sub { font-family:'DM Sans',sans-serif; font-size:14px; color:var(--muted); line-height:1.7; margin-bottom:24px; }
.cab-success-dets { background:var(--cream); border:1px solid var(--border); border-radius:16px; padding:18px 20px; text-align:left; margin-bottom:20px; }
