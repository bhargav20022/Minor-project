const wishlist=new Set(JSON.parse(localStorage.getItem('wl_wishlist')||'[]'));
function toggleWishlist(e,id){e.preventDefault();e.stopPropagation();const btn=e.currentTarget,icon=btn.querySelector('i');if(wishlist.has(id)){wishlist.delete(id);icon.className='fa-regular fa-heart';btn.classList.remove('liked');}else{wishlist.add(id);icon.className='fa-solid fa-heart';btn.classList.add('liked');btn.animate([{transform:'scale(1)'},{transform:'scale(1.4)'},{transform:'scale(1)'}],{duration:300,easing:'ease'});}localStorage.setItem('wl_wishlist',JSON.stringify([...wishlist]));}
