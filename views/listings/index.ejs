/* ═══ SHOW ATTRACTIONS ═══ */
function showCityAttractions(city) {
  const section  = document.getElementById('cityAttractionsSection');
  const grid     = document.getElementById('attractionsGrid');
  const nameEl   = document.getElementById('attractionsCityName');
  const emojiEl  = document.getElementById('attractionsCityEmoji');

  // Find closest matching key
  const cityLower = city.toLowerCase();
  const matchedKey = Object.keys(CITY_ATTRACTIONS).find(k =>
    cityLower.includes(k) || k.includes(cityLower)
  );

  nameEl.textContent  = city;
  emojiEl.textContent = getEmoji(city);

  if (!matchedKey) {
    grid.innerHTML = `<div class="no-attractions">
      <span style="font-size:32px;display:block;margin-bottom:10px">🗺️</span>
      Attractions for <strong>${city}</strong> are coming soon!
    </div>`;
    section.style.display = 'block';
    return;
  }

  grid.innerHTML = CITY_ATTRACTIONS[matchedKey].map(a => `
    <div class="attraction-card">
      <div class="attraction-img-wrap">
        <div class="attraction-emoji-thumb">${a.emoji}</div>
        <span class="attraction-tag">${a.tag}</span>
      </div>
      <div class="attraction-body">
        <div class="attraction-name">${a.name}</div>
        <div class="attraction-desc">${a.desc}</div>
      </div>
    </div>
  `).join('');

  section.style.display = 'block';
// At the END of showCityResults(), before the closing }
showCityAttractions(city);   // ← ADD THIS LINE
}
