function sortListings(){const val=document.getElementById('sortSelect').value,grid=document.getElementById('allListingsGrid'),cards=[...grid.querySelectorAll('.listing-link')];cards.sort((a,b)=>{const dA=ALL_LISTINGS.find(l=>l._id==a.dataset.id),dB=ALL_LISTINGS.find(l=>l._id==b.dataset.id);if(!dA||!dB)return 0;if(val==='price-asc')return(dA.price||0)-(dB.price||0);if(val==='price-desc')return(dB.price||0)-(dA.price||0);if(val==='name-asc')return(dA.title||'').localeCompare(dB.title||'');return 0;});cards.forEach(c=>grid.appendChild(c));}

/* ═══ CAB BOOKING ═══ */
let selectedCar = { name:'Micro', rate:8 };

function openCabModal(type, icon, rate) {
  selectedCar = { name: type, rate: rate };
  document.getElementById('cabModalTtl').textContent = icon + ' ' + type;
  document.getElementById('cabModalSub').textContent = 'Fill in your details below';
  document.getElementById('cabFormBody').style.display = 'block';
  document.getElementById('cabSuccessBox').classList.remove('show');
  document.getElementById('cabFareEst').classList.remove('show');
  document.getElementById('cabOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
  // Pre-select matching car type
  document.querySelectorAll('.cab-car-type').forEach(c => {
    c.classList.toggle('selected', c.dataset.car === (rate===8&&type==='Airport Transfer'?'Micro': rate===12?'Sedan':'SUV'));
  });
  document.getElementById('cabCarLabel').textContent = selectedCar.name;
}

function closeCabModal() {
  document.getElementById('cabOverlay').classList.remove('open');
  document.body.style.overflow = '';
}
function closeCabOnOverlay(e) { if(e.target===document.getElementById('cabOverlay'))closeCabModal(); }

function selectCar(el, name, rate) {
  document.querySelectorAll('.cab-car-type').forEach(c=>c.classList.remove('selected'));
  el.classList.add('selected');
  selectedCar = { name, rate };
  document.getElementById('cabCarLabel').textContent = name;
  updateFare();
}

function swapLocations() {
  const p=document.getElementById('cabPickup'),d=document.getElementById('cabDrop');
  const tmp=p.value; p.value=d.value; d.value=tmp;
}

function updateFare() {
  const pickup=document.getElementById('cabPickup').value.trim();
  const drop=document.getElementById('cabDrop').value.trim();
  const date=document.getElementById('cabDate').value;
  const est=document.getElementById('cabFareEst');
  if(pickup && drop && date) {
    const seed=(pickup.length+drop.length)%28+8;
    const fare=seed*selectedCar.rate;
    document.getElementById('cabFareAmt').textContent=`₹${fare.toLocaleString('en-IN')}`;
    est.classList.add('show');
  } else { est.classList.remove('show'); }
}

['cabPickup','cabDrop'].forEach(id=>{
  document.getElementById(id).addEventListener('input',updateFare);
});

function submitCabBooking() {
  const pickup=document.getElementById('cabPickup').value.trim();
  const drop=document.getElementById('cabDrop').value.trim();
  const date=document.getElementById('cabDate').value;
  const time=document.getElementById('cabTime').value;
  const passengers=document.getElementById('cabPassengers').value;
  if(!pickup){shake('cabPickup');return;}
  if(!drop){shake('cabDrop');return;}
  if(!date){shake('cabDate');return;}
  if(!time){shake('cabTime');return;}
  const seed=(pickup.length+drop.length)%28+8;
  const fare=seed*selectedCar.rate;
  const ref='CAB-'+Date.now().toString(36).toUpperCase();
  const fd=new Date(date).toDateString();
  const [h,m]=time.split(':');
  const hr=parseInt(h);
  const ft=`${hr>12?hr-12:hr||12}:${m} ${hr>=12?'PM':'AM'}`;
  document.getElementById('cabSuccessDets').innerHTML=`
    <div class="cab-srow"><span>Pickup</span><span>${pickup}</span></div>
    <div class="cab-srow"><span>Drop</span><span>${drop}</span></div>
    <div class="cab-srow"><span>Date &amp; Time</span><span>${fd}, ${ft}</span></div>
    <div class="cab-srow"><span>Car Type</span><span>${selectedCar.name}</span></div>
    <div class="cab-srow"><span>Passengers</span><span>${passengers}</span></div>
    <div class="cab-srow"><span>Est. Fare</span><span style="color:var(--accent);font-size:16px">₹${fare.toLocaleString('en-IN')}</span></div>
    <div class="cab-srow"><span>Booking Ref</span><span style="color:var(--muted);font-size:12px">${ref}</span></div>`;
  document.getElementById('cabFormBody').style.display='none';
  document.getElementById('cabSuccessBox').classList.add('show');
}

function shake(id){
  const el=document.getElementById(id);
  el.style.borderColor='#dc3545';
  el.animate([{transform:'translateX(0)'},{transform:'translateX(-6px)'},{transform:'translateX(6px)'},{transform:'translateX(0)'}],{duration:300,easing:'ease'});
  setTimeout(()=>el.style.borderColor='',1000);
}

document.addEventListener('keydown',e=>{if(e.key==='Escape')closeCabModal();});
