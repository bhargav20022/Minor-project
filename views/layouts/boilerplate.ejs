<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="google-site-verification" content="glIIyt9H6ugqn7y5WHtHdN67lHVz28OuVepExB1UgeA" />
  <title>WANDERLUST</title>



  <!-- Bootstrap CSS -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
    integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
    crossorigin="anonymous"
  />

  <!-- Font Awesome -->
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
  />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap"
    rel="stylesheet"
  />

  <!-- Leaflet CSS -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

  <!-- Star Ratings -->
  <link href="/css/rating.css" rel="stylesheet"/>

  <!-- Your custom styles -->
  <link rel="stylesheet" href="/css/style.css"/>

  <style>
    /* ── GLOBAL BASE ── */
    *, *::before, *::after { box-sizing: border-box; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: #faf7f2;
      color: #1a1a2e;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    body > .container { flex: 1; }

    .alert {
      border-radius: 12px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem;
      border: none;
    }

    .alert-success {
      background: rgba(45,122,79,0.1);
      color: #1e5c38;
      border-left: 4px solid #2d7a4f;
    }

    .alert-danger,
    .alert-error {
      background: rgba(220,53,69,0.08);
      color: #842029;
      border-left: 4px solid #dc3545;
    }

    .alert .btn-close {
      position: absolute;
      top: 50%;
      right: 14px;
      transform: translateY(-50%);
      opacity: 0.6;
      z-index: 10;
      pointer-events: all;
    }
    .alert .btn-close:hover { opacity: 1; }

    .alert-dismissible { position: relative; padding-right: 3rem; }
  </style>
</head>

<body>
  <%- include("../includes/navbar.ejs") %>

  <div class="container py-3">
    <%- include("../includes/flash.ejs") %>
    <%- body %>
  </div>

  <%- include("../includes/footer.ejs") %>

  <!-- ✅ Bootstrap JS Bundle with CORRECT hash -->
  <script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
    crossorigin="anonymous"
  ></script>

  <!-- Leaflet JS -->
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

  <script src="/js/script.js"></script>

<script>
  async function loadNotifications() {
    try {
      const res = await fetch("/notifications");
      if (!res.ok) return;
      const data = await res.json();

      const badge = document.getElementById("notifBadge");
      const list  = document.getElementById("notifList");
      if (!badge || !list) return;

      // Badge
      if (data.unreadCount > 0) {
        badge.style.display = "inline-flex";
        badge.textContent = data.unreadCount;
      } else {
        badge.style.display = "none";
      }

      // List
      if (data.notifications.length === 0) {
        list.innerHTML = `
          <li style="padding:24px 16px;text-align:center;color:rgba(255,255,255,0.35);font-family:'DM Sans',sans-serif;font-size:13px;">
            <i class="fa-solid fa-bell-slash" style="font-size:22px;margin-bottom:8px;display:block;"></i>
            No notifications yet
          </li>`;
        return;
      }

      list.innerHTML = data.notifications.map(n => `
        <li onclick="markRead('${n._id}', this)" style="
          padding:13px 16px; border-bottom:1px solid rgba(255,255,255,0.06);
          cursor:pointer; transition:background 0.15s;
          background:${n.isRead ? 'transparent' : 'rgba(201,120,58,0.08)'};
          border-left:${n.isRead ? '3px solid transparent' : '3px solid #c9783a'};
        ">
          <strong style="display:block;font-size:13px;color:white;margin-bottom:3px;font-family:'DM Sans',sans-serif;">${n.title}</strong>
          <p style="margin:0 0 5px;font-size:12px;color:rgba(255,255,255,0.55);font-family:'DM Sans',sans-serif;line-height:1.5;">${n.message}</p>
          <small style="color:rgba(255,255,255,0.25);font-size:11px;font-family:'DM Sans',sans-serif;">${new Date(n.createdAt).toLocaleDateString()}</small>
        </li>
      `).join("");
    } catch(e) {}
  }

  async function markRead(id, el) {
    await fetch(`/notifications/${id}/read`, { method: "PUT" });
    el.style.background = "transparent";
    el.style.borderLeft = "3px solid transparent";
    loadNotifications();
  }

  async function markAllRead() {
    await fetch("/notifications/read-all", { method: "PUT" });
    loadNotifications();
  }

  function toggleNotifDropdown(e) {
    e.stopPropagation();
    const d = document.getElementById("notifDropdown");
    if (!d) return;
    const isOpen = d.style.display === "block";
    // Close profile dropdown if open
    const profileDd = document.getElementById("wlProfileDropdown");
    if (profileDd) profileDd.classList.remove("open");
    d.style.display = isOpen ? "none" : "block";
    if (!isOpen) loadNotifications();
  }

  // Close notif dropdown when clicking outside
  document.addEventListener("click", function(e) {
    const wrap = document.getElementById("wlNotifWrap");
    const d    = document.getElementById("notifDropdown");
    if (d && wrap && !wrap.contains(e.target)) {
      d.style.display = "none";
    }
  });

  loadNotifications();
  setInterval(loadNotifications, 30000);
</script>
</body>
</html>
