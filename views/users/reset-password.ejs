<% layout("/layouts/boilerplate") %>

<style>
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&family=DM+Sans:wght@300;400;500;600&display=swap');

.fp-wrapper {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #080810;
  padding: 24px;
  position: relative;
  overflow: hidden;
  font-family: 'DM Sans', sans-serif;
}
.fp-wrapper::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 50% at 20% 40%, rgba(212,168,67,.14) 0%, transparent 60%),
    radial-gradient(ellipse 50% 60% at 80% 60%, rgba(201,120,58,.1) 0%, transparent 55%);
}
.fp-wrapper::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(rgba(255,255,255,.03) 1px, transparent 1px);
  background-size: 28px 28px;
}
.fp-card {
  background: #faf7f2;
  border-radius: 28px;
  width: 100%;
  max-width: 440px;
  padding: 48px 44px;
  position: relative;
  z-index: 1;
  box-shadow: 0 32px 80px rgba(0,0,0,.5);
  animation: cardReveal .5s cubic-bezier(.34,1.56,.64,1) both;
}
@keyframes cardReveal {
  from { opacity:0; transform:translateY(30px) scale(.96); }
  to   { opacity:1; transform:translateY(0) scale(1); }
}
.fp-card::before {
  content: '';
  position: absolute;
  top: -1px; left: -1px; right: -1px; bottom: -1px;
  border-radius: 28px;
  background: linear-gradient(135deg, rgba(212,168,67,.35), rgba(201,120,58,.2), transparent 60%);
  z-index: -1;
}
.fp-icon-wrap {
  width: 72px; height: 72px;
  background: linear-gradient(135deg, #2a1a08, #c9783a);
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30px;
  margin: 0 auto 24px;
  box-shadow: 0 8px 24px rgba(201,120,58,.35);
  animation: iconPop .6s cubic-bezier(.34,1.56,.64,1) .2s both;
}
@keyframes iconPop {
  from { opacity:0; transform:scale(.5); }
  to   { opacity:1; transform:scale(1); }
}
.fp-steps {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  margin-bottom: 28px;
}
.fp-step-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  background: #e0d8cc;
}
.fp-step-dot.done   { background: #27ae60; }
.fp-step-dot.active { background: #c9783a; box-shadow: 0 0 0 3px rgba(201,120,58,.2); }
.fp-step-line {
  width: 40px; height: 2px;
  background: #e0d8cc;
}
.fp-step-line.done { background: #27ae60; }

.fp-flash {
  border-radius: 12px;
  padding: 12px 16px;
  font-size: 13px;
  font-weight: 500;
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.fp-flash-error   { background: #fff1f0; border: 1px solid #ffd4d0; color: #c0392b; }
.fp-flash-success { background: #f0fff4; border: 1px solid #b7ebc8; color: #27ae60; }

.fp-eyebrow {
  text-align: center;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #c9783a;
  margin-bottom: 10px;
}
.fp-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 34px;
  font-weight: 600;
  color: #1a1a2e;
  text-align: center;
  margin-bottom: 8px;
  line-height: 1.15;
}
.fp-title em { font-style: italic; color: #c9783a; }
.fp-subtitle {
  text-align: center;
  font-size: 13.5px;
  color: #7a7a8a;
  margin-bottom: 32px;
  font-weight: 300;
  line-height: 1.6;
}

.fp-field { margin-bottom: 20px; }
.fp-label {
  display: block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: #7a7a8a;
  margin-bottom: 8px;
}
.fp-input-wrap { position: relative; display: flex; align-items: center; }
.fp-input-icon {
  position: absolute;
  left: 16px;
  color: #c0bab4;
  font-size: 15px;
  pointer-events: none;
  transition: color .2s;
}
.fp-input {
  width: 100%;
  padding: 14px 44px 14px 44px;
  border: 2px solid #e8e2d9;
  border-radius: 12px;
  font-family: 'DM Sans', sans-serif;
  font-size: 14.5px;
  color: #1a1a2e;
  background: #fff;
  outline: none;
  transition: border-color .2s, box-shadow .2s;
}
.fp-input::placeholder { color: #c0bab4; }
.fp-input:focus {
  border-color: #c9783a;
  box-shadow: 0 0 0 4px rgba(201,120,58,.1);
}
.fp-input-wrap:focus-within .fp-input-icon { color: #c9783a; }

.pw-toggle {
  position: absolute;
  right: 14px;
  background: none;
  border: none;
  cursor: pointer;
  color: #c0bab4;
  font-size: 15px;
  padding: 4px;
  transition: color .2s;
}
.pw-toggle:hover { color: #c9783a; }

/* strength meter */
.pw-strength-wrap { margin-top: 8px; display: none; }
.pw-strength-wrap.show { display: block; }
.pw-strength-bar {
  height: 4px;
  background: #e8e2d9;
  border-radius: 10px;
  overflow: hidden;
  margin-bottom: 5px;
}
.pw-strength-fill {
  height: 100%;
  border-radius: 10px;
  transition: width .3s ease, background .3s ease;
  width: 0%;
}
.pw-strength-text { font-size: 11px; font-weight: 600; color: #7a7a8a; }

/* match indicator */
.pw-match {
  font-size: 11px;
  font-weight: 600;
  margin-top: 6px;
  display: none;
}
.pw-match.show { display: block; }
.pw-match.ok  { color: #27ae60; }
.pw-match.bad { color: #e74c3c; }

.fp-btn {
  width: 100%;
  padding: 15px;
  background: linear-gradient(135deg, #1a1a2e, #c9783a);
  color: white;
  border: none;
  border-radius: 12px;
  font-family: 'DM Sans', sans-serif;
  font-size: 15px;
  font-weight: 600;
  cursor: pointer;
  transition: all .25s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin-top: 8px;
}
.fp-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(201,120,58,.4); }
.fp-btn:disabled { opacity: .5; cursor: default; transform: none; }

/* rules checklist */
.pw-rules {
  background: #f0ebe0;
  border-radius: 12px;
  padding: 14px 16px;
  margin-bottom: 20px;
}
.pw-rule {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: #7a7a8a;
  margin-bottom: 6px;
}
.pw-rule:last-child { margin-bottom: 0; }
.pw-rule i { font-size: 12px; color: #c0bab4; transition: color .2s; }
.pw-rule.ok i { color: #27ae60; }
.pw-rule.ok span { color: #1a1a2e; }
</style>

<div class="fp-wrapper">
  <div class="fp-card">

    <div class="fp-icon-wrap">🔑</div>

    <!-- steps: step 3 active -->
    <div class="fp-steps">
      <div class="fp-step-dot done"></div>
      <div class="fp-step-line done"></div>
      <div class="fp-step-dot done"></div>
      <div class="fp-step-line done"></div>
      <div class="fp-step-dot active"></div>
    </div>

    <% if(success && success.length) { %>
      <div class="fp-flash fp-flash-success">
        <i class="fa-solid fa-circle-check"></i> <%= success %>
      </div>
    <% } %>
    <% if(error && error.length) { %>
      <div class="fp-flash fp-flash-error">
        <i class="fa-solid fa-triangle-exclamation"></i> <%= error %>
      </div>
    <% } %>

    <div class="fp-eyebrow">Step 3 of 3</div>
    <h1 class="fp-title">Set a new<br/><em>password</em></h1>
    <p class="fp-subtitle">Choose a strong password for your account.</p>

    <!-- password rules -->
    <div class="pw-rules">
      <div class="pw-rule" id="rule-len"><i class="fa-solid fa-circle-dot"></i><span>At least 6 characters</span></div>
      <div class="pw-rule" id="rule-upper"><i class="fa-solid fa-circle-dot"></i><span>One uppercase letter</span></div>
      <div class="pw-rule" id="rule-num"><i class="fa-solid fa-circle-dot"></i><span>One number</span></div>
    </div>

    <form action="/reset-password" method="POST" id="resetForm">

      <div class="fp-field">
        <label class="fp-label" for="password">New Password</label>
        <div class="fp-input-wrap">
          <i class="fa-solid fa-lock fp-input-icon"></i>
          <input type="password" id="password" name="password" class="fp-input" placeholder="Enter new password" autocomplete="new-password" required/>
          <button type="button" class="pw-toggle" onclick="togglePw('password',this)" tabindex="-1">
            <i class="fa-regular fa-eye"></i>
          </button>
        </div>
        <div class="pw-strength-wrap" id="pwStrengthWrap">
          <div class="pw-strength-bar">
            <div class="pw-strength-fill" id="pwStrengthFill"></div>
          </div>
          <span class="pw-strength-text" id="pwStrengthText"></span>
        </div>
      </div>

      <div class="fp-field">
        <label class="fp-label" for="confirmPassword">Confirm Password</label>
        <div class="fp-input-wrap">
          <i class="fa-solid fa-lock fp-input-icon"></i>
          <input type="password" id="confirmPassword" name="confirmPassword" class="fp-input" placeholder="Re-enter your password" autocomplete="new-password" required/>
          <button type="button" class="pw-toggle" onclick="togglePw('confirmPassword',this)" tabindex="-1">
            <i class="fa-regular fa-eye"></i>
          </button>
        </div>
        <div class="pw-match" id="pwMatch"></div>
      </div>

      <button type="submit" class="fp-btn" id="resetBtn" disabled>
        <i class="fa-solid fa-key"></i> Reset Password
      </button>

    </form>

  </div>
</div>

<script>
function togglePw(id, btn) {
  const input = document.getElementById(id);
  const icon  = btn.querySelector('i');
  input.type  = input.type === 'password' ? 'text' : 'password';
  icon.className = input.type === 'password' ? 'fa-regular fa-eye' : 'fa-regular fa-eye-slash';
}

const pwInput    = document.getElementById('password');
const confirmPw  = document.getElementById('confirmPassword');
const pwWrap     = document.getElementById('pwStrengthWrap');
const pwFill     = document.getElementById('pwStrengthFill');
const pwText     = document.getElementById('pwStrengthText');
const pwMatch    = document.getElementById('pwMatch');
const resetBtn   = document.getElementById('resetBtn');

const rules = {
  len:   document.getElementById('rule-len'),
  upper: document.getElementById('rule-upper'),
  num:   document.getElementById('rule-num'),
};

const levels = [
  { label:'Weak',     color:'#e74c3c', width:'25%' },
  { label:'Fair',     color:'#e67e22', width:'50%' },
  { label:'Good',     color:'#f1c40f', width:'75%' },
  { label:'Strong 💪',color:'#27ae60', width:'100%'},
];

function getStrength(pw) {
  let s = 0;
  if (pw.length >= 6)  s++;
  if (pw.length >= 10) s++;
  if (/[A-Z]/.test(pw)) s++;
  if (/[0-9]/.test(pw)) s++;
  return Math.min(s, 3);
}

function checkRules(pw) {
  const r = { len: pw.length >= 6, upper: /[A-Z]/.test(pw), num: /[0-9]/.test(pw) };
  Object.entries(r).forEach(([k, ok]) => {
    rules[k].classList.toggle('ok', ok);
    rules[k].querySelector('i').className = ok
      ? 'fa-solid fa-circle-check' : 'fa-solid fa-circle-dot';
  });
  return r.len && r.upper && r.num;
}

pwInput.addEventListener('input', () => {
  const val = pwInput.value;
  if (!val) { pwWrap.classList.remove('show'); checkRules(''); updateBtn(); return; }
  pwWrap.classList.add('show');
  const lvl = getStrength(val);
  pwFill.style.width      = levels[lvl].width;
  pwFill.style.background = levels[lvl].color;
  pwText.textContent      = levels[lvl].label;
  pwText.style.color      = levels[lvl].color;
  checkRules(val);
  checkMatch();
  updateBtn();
});

confirmPw.addEventListener('input', () => { checkMatch(); updateBtn(); });

function checkMatch() {
  if (!confirmPw.value) { pwMatch.classList.remove('show'); return; }
  const ok = pwInput.value === confirmPw.value;
  pwMatch.className = 'pw-match show ' + (ok ? 'ok' : 'bad');
  pwMatch.innerHTML = ok
    ? '<i class="fa-solid fa-circle-check"></i> Passwords match!'
    : '<i class="fa-solid fa-circle-xmark"></i> Passwords do not match';
}

function updateBtn() {
  const rulesOk = checkRules(pwInput.value);
  const matchOk = pwInput.value && pwInput.value === confirmPw.value;
  resetBtn.disabled = !(rulesOk && matchOk);
}
</script>
