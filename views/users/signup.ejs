<% layout("/layouts/boilerplate") %>

<style>
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400;1,600&family=DM+Sans:wght@300;400;500;600&display=swap');

/* ══ RESET & BASE ══ */
.auth-page-wrapper {
  min-height: 100vh;
  display: flex;
  align-items: stretch;
  background: #080810;
  font-family: 'DM Sans', sans-serif;
  position: relative;
  overflow: hidden;
}

/* ══ LEFT PANEL — visual ══ */
.auth-visual {
  flex: 1;
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 52px;
  overflow: hidden;
  min-height: 100vh;
}
.auth-visual-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(160deg, #0c1a1f 0%, #0f2818 40%, #1a1a0c 100%);
  z-index: 0;
}
.auth-visual-bg::after {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 70% 50% at 20% 30%, rgba(45,170,90,.15) 0%, transparent 60%),
    radial-gradient(ellipse 50% 60% at 80% 70%, rgba(212,168,67,.12) 0%, transparent 55%),
    radial-gradient(ellipse 40% 40% at 50% 10%, rgba(20,120,100,.12) 0%, transparent 55%);
}
.orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(60px);
  animation: orbFloat 8s ease-in-out infinite;
  z-index: 0;
}
.orb-1 { width:320px; height:320px; background:rgba(45,170,90,.12); top:-80px; left:-80px; animation-delay:0s; }
.orb-2 { width:240px; height:240px; background:rgba(212,168,67,.1); bottom:120px; right:-60px; animation-delay:-3s; }
.orb-3 { width:180px; height:180px; background:rgba(20,180,150,.1); top:50%; left:40%; animation-delay:-5s; }
@keyframes orbFloat {
  0%,100% { transform: translateY(0) scale(1); }
  50%      { transform: translateY(-30px) scale(1.07); }
}
.auth-visual-grid {
  position: absolute;
  inset: 0;
  background-image: radial-gradient(rgba(255,255,255,.04) 1px, transparent 1px);
  background-size: 28px 28px;
  z-index: 0;
}

/* journey steps — unique to signup */
.journey-steps {
  position: absolute;
  top: 50%;
  right: 52px;
  transform: translateY(-50%);
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.journey-step {
  display: flex;
  align-items: center;
  gap: 14px;
  animation: stepReveal .5s ease both;
}
.journey-step:nth-child(1) { animation-delay:.2s; }
.journey-step:nth-child(2) { animation-delay:.35s; }
.journey-step:nth-child(3) { animation-delay:.5s; }
.journey-step:nth-child(4) { animation-delay:.65s; }
@keyframes stepReveal {
  from { opacity:0; transform:translateX(20px); }
  to   { opacity:1; transform:translateX(0); }
}
.step-icon {
  width: 44px; height: 44px;
  background: rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.12);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
  backdrop-filter: blur(6px);
}
.step-text .step-title {
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  font-weight: 600;
  color: rgba(255,255,255,.7);
  margin-bottom: 2px;
}
.step-text .step-sub {
  font-size: 11px;
  color: rgba(255,255,255,.3);
}

.auth-visual-content { position: relative; z-index: 2; }
.auth-visual-logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px;
  font-weight: 600;
  color: #fff;
  letter-spacing: 2px;
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 48px;
}
.auth-visual-logo span {
  width: 8px; height: 8px;
  background: #d4a843;
  border-radius: 50%;
  display: inline-block;
}
.auth-visual-quote {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(30px, 3.2vw, 44px);
  font-weight: 300;
  color: #fff;
  line-height: 1.22;
  margin-bottom: 20px;
}
.auth-visual-quote em { font-style: italic; color: #d4a843; }
.auth-visual-sub {
  font-size: 14px;
  color: rgba(255,255,255,.38);
  font-weight: 300;
  margin-bottom: 36px;
}
.auth-visual-perks {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.perk-item {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 13px;
  color: rgba(255,255,255,.55);
}
.perk-dot {
  width: 6px; height: 6px;
  background: #d4a843;
  border-radius: 50%;
  flex-shrink: 0;
}

/* ══ RIGHT PANEL — form ══ */
.auth-form-panel {
  width: 500px;
  flex-shrink: 0;
  background: #faf7f2;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 52px 52px;
  position: relative;
  overflow: hidden;
}
.auth-form-panel::before {
  content: '';
  position: absolute;
  top: -120px; right: -120px;
  width: 300px; height: 300px;
  background: radial-gradient(circle, rgba(45,170,90,.07) 0%, transparent 70%);
  pointer-events: none;
}
.auth-form-panel::after {
  content: '';
  position: absolute;
  bottom: -80px; left: -80px;
  width: 220px; height: 220px;
  background: radial-gradient(circle, rgba(212,168,67,.06) 0%, transparent 70%);
  pointer-events: none;
}

.auth-form-eyebrow {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #2d9e5f;
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.auth-form-eyebrow::after {
  content: '';
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, #2d9e5f44, transparent);
}
.auth-form-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 38px;
  font-weight: 600;
  color: #1a1a2e;
  line-height: 1.1;
  margin-bottom: 8px;
}
.auth-form-title em { font-style: italic; color: #2d9e5f; }
.auth-form-subtitle {
  font-size: 13.5px;
  color: #7a7a8a;
  margin-bottom: 28px;
  font-weight: 300;
}

/* flash messages */
.auth-flash {
  border-radius: 12px;
  padding: 12px 16px;
  font-size: 13px;
  font-weight: 500;
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.auth-flash-error   { background: #fff1f0; border: 1px solid #ffd4d0; color: #c0392b; }
.auth-flash-success { background: #f0fff4; border: 1px solid #b7ebc8; color: #27ae60; }

/* form fields */
.auth-field { margin-bottom: 18px; position: relative; }
.auth-label {
  display: block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: #7a7a8a;
  margin-bottom: 7px;
}
.auth-input-wrap { position: relative; display: flex; align-items: center; }
.auth-input-icon {
  position: absolute;
  left: 16px;
  color: #c0bab4;
  font-size: 15px;
  pointer-events: none;
  transition: color .2s;
  z-index: 1;
}
.auth-input {
  width: 100%;
  padding: 13px 16px 13px 44px;
  border: 2px solid #e8e2d9;
  border-radius: 12px;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  color: #1a1a2e;
  background: #fff;
  outline: none;
  transition: border-color .2s, box-shadow .2s, background .2s;
}
.auth-input::placeholder { color: #c0bab4; }
.auth-input:focus {
  border-color: #2d9e5f;
  box-shadow: 0 0 0 4px rgba(45,158,95,.1);
  background: #f9fff9;
}
.auth-input:focus + .auth-input-icon,
.auth-input-wrap:focus-within .auth-input-icon { color: #2d9e5f; }

/* validation check icon */
.auth-input.valid   { border-color: #27ae60; }
.auth-input.invalid { border-color: #e74c3c; }
.field-check {
  position: absolute;
  right: 14px;
  font-size: 14px;
  pointer-events: none;
  opacity: 0;
  transition: opacity .2s;
}
.field-check.show { opacity: 1; }
.field-check.ok  { color: #27ae60; }
.field-check.bad { color: #e74c3c; }

/* password toggle */
.pw-toggle {
  position: absolute;
  right: 14px;
  background: none;
  border: none;
  cursor: pointer;
  color: #c0bab4;
  font-size: 15px;
  padding: 4px;
  transition: color .2s;
  z-index: 1;
}
.pw-toggle:hover { color: #2d9e5f; }

/* password strength meter */
.pw-strength-wrap {
  margin-top: 8px;
  display: none;
}
.pw-strength-wrap.show { display: block; }
.pw-strength-bar {
  height: 4px;
  background: #e8e2d9;
  border-radius: 10px;
  overflow: hidden;
  margin-bottom: 5px;
}
.pw-strength-fill {
  height: 100%;
  border-radius: 10px;
  transition: width .3s ease, background .3s ease;
  width: 0%;
}
.pw-strength-text {
  font-size: 11px;
  font-weight: 600;
  color: #7a7a8a;
}

/* 2-col row */
.auth-row2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}
@media(max-width:480px) { .auth-row2 { grid-template-columns: 1fr; } }

/* terms */
.auth-terms {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 12.5px;
  color: #7a7a8a;
  margin-bottom: 20px;
  line-height: 1.5;
}
.auth-terms input[type="checkbox"] {
  width: 16px; height: 16px;
  flex-shrink: 0;
  margin-top: 2px;
  accent-color: #2d9e5f;
  cursor: pointer;
}
.auth-terms a { color: #2d9e5f; text-decoration: none; font-weight: 600; }
.auth-terms a:hover { text-decoration: underline; }

/* submit */
.auth-submit-btn {
  width: 100%;
  padding: 15px;
  background: linear-gradient(135deg, #1a3a28 0%, #2d9e5f 100%);
  color: white;
  border: none;
  border-radius: 12px;
  font-family: 'DM Sans', sans-serif;
  font-size: 15px;
  font-weight: 600;
  cursor: pointer;
  transition: all .25s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin-bottom: 20px;
  position: relative;
  overflow: hidden;
  letter-spacing: .3px;
}
.auth-submit-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,.15), transparent);
  opacity: 0;
  transition: opacity .25s;
}
.auth-submit-btn:hover::before { opacity: 1; }
.auth-submit-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(45,158,95,.4); }
.auth-submit-btn:active { transform: translateY(0); }

/* divider */
.auth-divider {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 20px;
  font-size: 12px;
  color: #b0a8a0;
}
.auth-divider::before, .auth-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: #e8e2d9;
}

/* switch */
.auth-switch { text-align: center; font-size: 13.5px; color: #7a7a8a; }
.auth-switch a { color: #2d9e5f; font-weight: 600; text-decoration: none; transition: color .2s; }
.auth-switch a:hover { color: #1a7a45; text-decoration: underline; }

/* progress steps indicator at top */
.signup-steps {
  display: flex;
  align-items: center;
  gap: 0;
  margin-bottom: 28px;
}
.signup-step-dot {
  width: 28px; height: 28px;
  background: #e8e2d9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  font-weight: 700;
  color: #b0a8a0;
  flex-shrink: 0;
  transition: all .3s;
}
.signup-step-dot.active {
  background: #2d9e5f;
  color: white;
  box-shadow: 0 0 0 4px rgba(45,158,95,.15);
}
.signup-step-dot.done {
  background: #1a7a45;
  color: white;
}
.signup-step-line {
  flex: 1;
  height: 2px;
  background: #e8e2d9;
  transition: background .3s;
}
.signup-step-line.done { background: #2d9e5f; }

/* animations */
.auth-form-panel > * {
  animation: slideInRight .5s cubic-bezier(.25,.8,.25,1) both;
}
.auth-form-panel > *:nth-child(1) { animation-delay:.05s; }
.auth-form-panel > *:nth-child(2) { animation-delay:.1s; }
.auth-form-panel > *:nth-child(3) { animation-delay:.15s; }
.auth-form-panel > *:nth-child(4) { animation-delay:.2s; }
.auth-form-panel > *:nth-child(5) { animation-delay:.25s; }
@keyframes slideInRight {
  from { opacity:0; transform:translateX(24px); }
  to   { opacity:1; transform:translateX(0); }
}
.auth-visual-content > * {
  animation: slideInLeft .6s cubic-bezier(.25,.8,.25,1) both;
}
.auth-visual-content > *:nth-child(1) { animation-delay:.1s; }
.auth-visual-content > *:nth-child(2) { animation-delay:.2s; }
.auth-visual-content > *:nth-child(3) { animation-delay:.3s; }
.auth-visual-content > *:nth-child(4) { animation-delay:.4s; }
@keyframes slideInLeft {
  from { opacity:0; transform:translateX(-24px); }
  to   { opacity:1; transform:translateX(0); }
}

/* responsive */
@media (max-width: 900px) {
  .auth-visual { display: none; }
  .auth-form-panel { width: 100%; padding: 48px 28px; min-height: 100vh; }
}
@media (max-width: 480px) {
  .auth-form-panel { padding: 36px 20px; }
  .auth-form-title { font-size: 30px; }
}
</style>

<div class="auth-page-wrapper">

  <!-- ══ LEFT: Visual Panel ══ -->
  <div class="auth-visual">
    <div class="auth-visual-bg"></div>
    <div class="auth-visual-grid"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <!-- journey steps -->
    <div class="journey-steps">
      <div class="journey-step">
        <div class="step-icon">🔍</div>
        <div class="step-text">
          <div class="step-title">Discover</div>
          <div class="step-sub">Browse 500+ stays</div>
        </div>
      </div>
      <div class="journey-step">
        <div class="step-icon">🗺️</div>
        <div class="step-text">
          <div class="step-title">Explore</div>
          <div class="step-sub">80+ cities covered</div>
        </div>
      </div>
      <div class="journey-step">
        <div class="step-icon">❤️</div>
        <div class="step-text">
          <div class="step-title">Save</div>
          <div class="step-sub">Wishlist your favourites</div>
        </div>
      </div>
      <div class="journey-step">
        <div class="step-icon">🏠</div>
        <div class="step-text">
          <div class="step-title">Stay</div>
          <div class="step-sub">Book &amp; enjoy</div>
        </div>
      </div>
    </div>

    <div class="auth-visual-content">
      <div class="auth-visual-logo">
        <span></span> Wanderlust
      </div>
      <div class="auth-visual-quote">
        Your next <em>adventure</em><br/>is one step away
      </div>
      <p class="auth-visual-sub">Join thousands of travellers who found their perfect stay</p>
      <div class="auth-visual-perks">
        <div class="perk-item"><div class="perk-dot"></div> Free to join — no hidden fees</div>
        <div class="perk-item"><div class="perk-dot"></div> Exclusive deals for members</div>
        <div class="perk-item"><div class="perk-dot"></div> Save &amp; track your favourite stays</div>
        <div class="perk-item"><div class="perk-dot"></div> List your own property</div>
      </div>
    </div>
  </div>

  <!-- ══ RIGHT: Form Panel ══ -->
  <div class="auth-form-panel">

    <!-- Flash messages -->
    <% if(success && success.length) { %>
      <div class="auth-flash auth-flash-success">
        <i class="fa-solid fa-circle-check"></i> <%= success %>
      </div>
    <% } %>
    <% if(error && error.length) { %>
      <div class="auth-flash auth-flash-error">
        <i class="fa-solid fa-triangle-exclamation"></i> <%= error %>
      </div>
    <% } %>

    <!-- progress steps -->
    <div class="signup-steps">
      <div class="signup-step-dot active">1</div>
      <div class="signup-step-line" id="line1"></div>
      <div class="signup-step-dot" id="step2">2</div>
      <div class="signup-step-line" id="line2"></div>
      <div class="signup-step-dot" id="step3">3</div>
    </div>

    <div class="auth-form-eyebrow">Create account</div>
    <h1 class="auth-form-title">Join <em>Wanderlust</em><br/>for free</h1>
    <p class="auth-form-subtitle">Start exploring handpicked stays in seconds</p>

    <form action="/signup" method="POST" class="needs-validation" novalidate id="signupForm">

      <div class="auth-field">
        <label class="auth-label" for="username">Username</label>
        <div class="auth-input-wrap">
          <i class="fa-solid fa-user auth-input-icon"></i>
          <input
            type="text"
            id="username"
            name="username"
            class="auth-input"
            placeholder="Choose a username"
            autocomplete="username"
            required
          />
          <span class="field-check" id="usernameCheck"></span>
        </div>
      </div>

      <div class="auth-field">
        <label class="auth-label" for="email">Email Address</label>
        <div class="auth-input-wrap">
          <i class="fa-solid fa-envelope auth-input-icon"></i>
          <input
            type="email"
            id="email"
            name="email"
            class="auth-input"
            placeholder="your@email.com"
            autocomplete="email"
            required
          />
          <span class="field-check" id="emailCheck"></span>
        </div>
      </div>

      <div class="auth-field">
        <label class="auth-label" for="password">Password</label>
        <div class="auth-input-wrap">
          <i class="fa-solid fa-lock auth-input-icon"></i>
          <input
            type="password"
            id="password"
            name="password"
            class="auth-input"
            placeholder="Create a strong password"
            autocomplete="new-password"
            required
          />
          <button type="button" class="pw-toggle" onclick="togglePw('password', this)" tabindex="-1">
            <i class="fa-regular fa-eye"></i>
          </button>
        </div>
        <!-- password strength -->
        <div class="pw-strength-wrap" id="pwStrengthWrap">
          <div class="pw-strength-bar">
            <div class="pw-strength-fill" id="pwStrengthFill"></div>
          </div>
          <span class="pw-strength-text" id="pwStrengthText">Too short</span>
        </div>
      </div>

      <div class="auth-terms">
        <input type="checkbox" id="agreeTerms" required/>
        <label for="agreeTerms">
          I agree to the <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>
        </label>
      </div>

      <button type="submit" class="auth-submit-btn">
        <i class="fa-solid fa-rocket"></i>
        Create My Account
      </button>

    </form>

    <div class="auth-divider">already have an account?</div>

    <div class="auth-switch">
      <a href="/login">← Sign in instead</a>
    </div>

  </div>
</div>

<script>
/* ── password toggle ── */
function togglePw(fieldId, btn) {
  const input = document.getElementById(fieldId);
  const icon  = btn.querySelector('i');
  if (input.type === 'password') {
    input.type = 'text';
    icon.className = 'fa-regular fa-eye-slash';
  } else {
    input.type = 'password';
    icon.className = 'fa-regular fa-eye';
  }
}

/* ── password strength ── */
const pwInput       = document.getElementById('password');
const pwWrap        = document.getElementById('pwStrengthWrap');
const pwFill        = document.getElementById('pwStrengthFill');
const pwText        = document.getElementById('pwStrengthText');
const strengthLevels = [
  { label:'Too short',  color:'#e74c3c', width:'15%' },
  { label:'Weak',       color:'#e67e22', width:'30%' },
  { label:'Fair',       color:'#f1c40f', width:'55%' },
  { label:'Good',       color:'#2ecc71', width:'75%' },
  { label:'Strong 💪',  color:'#27ae60', width:'100%'},
];
function getStrength(pw) {
  let score = 0;
  if (pw.length >= 8)  score++;
  if (pw.length >= 12) score++;
  if (/[A-Z]/.test(pw)) score++;
  if (/[0-9]/.test(pw)) score++;
  if (/[^A-Za-z0-9]/.test(pw)) score++;
  return Math.min(score, 4);
}
pwInput.addEventListener('input', () => {
  const val = pwInput.value;
  if (!val) { pwWrap.classList.remove('show'); return; }
  pwWrap.classList.add('show');
  const level = getStrength(val);
  const s = strengthLevels[level];
  pwFill.style.width      = s.width;
  pwFill.style.background = s.color;
  pwText.textContent      = s.label;
  pwText.style.color      = s.color;
});

/* ── live field validation ── */
function validateField(input, checkEl, validator) {
  input.addEventListener('blur', () => {
    const ok = validator(input.value);
    input.classList.toggle('valid',   ok);
    input.classList.toggle('invalid', !ok);
    checkEl.className = 'field-check show ' + (ok ? 'ok' : 'bad');
    checkEl.innerHTML = ok
      ? '<i class="fa-solid fa-circle-check"></i>'
      : '<i class="fa-solid fa-circle-xmark"></i>';
  });
}
validateField(
  document.getElementById('username'),
  document.getElementById('usernameCheck'),
  v => v.trim().length >= 3
);
validateField(
  document.getElementById('email'),
  document.getElementById('emailCheck'),
  v => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)
);

/* ── progress step indicator ── */
const fields  = ['username','email','password'];
const step2El = document.getElementById('step2');
const step3El = document.getElementById('step3');
const line1   = document.getElementById('line1');
const line2   = document.getElementById('line2');
document.getElementById('username').addEventListener('input', updateProgress);
document.getElementById('email').addEventListener('input', updateProgress);
document.getElementById('password').addEventListener('input', updateProgress);
function updateProgress() {
  const u = document.getElementById('username').value.trim().length >= 3;
  const e = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(document.getElementById('email').value);
  const p = document.getElementById('password').value.length >= 6;
  if (u) { step2El.classList.add('active'); line1.classList.add('done'); }
  else   { step2El.classList.remove('active','done'); line1.classList.remove('done'); }
  if (u && e) { step2El.classList.add('done'); step3El.classList.add('active'); line2.classList.add('done'); }
  else        { step2El.classList.remove('done'); step3El.classList.remove('active','done'); line2.classList.remove('done'); }
  if (u && e && p) { step3El.classList.add('done'); }
  else             { step3El.classList.remove('done'); }
}
</script>
