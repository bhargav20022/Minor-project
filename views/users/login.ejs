<% layout("/layouts/boilerplate") %>

<style>
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400;1,600&family=DM+Sans:wght@300;400;500;600&display=swap');

/* ══ RESET & BASE ══ */
.auth-page-wrapper {
  min-height: 100vh;
  display: flex;
  align-items: stretch;
  background: #080810;
  font-family: 'DM Sans', sans-serif;
  position: relative;
  overflow: hidden;
}

/* ══ LEFT PANEL — visual ══ */
.auth-visual {
  flex: 1;
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 52px;
  overflow: hidden;
  min-height: 100vh;
}
.auth-visual-bg {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(160deg, #0c0c22 0%, #1a0f2e 40%, #0c1a1f 100%);
  z-index: 0;
}
.auth-visual-bg::after {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 70% 50% at 20% 30%, rgba(201,120,58,.18) 0%, transparent 60%),
    radial-gradient(ellipse 50% 60% at 80% 70%, rgba(212,168,67,.12) 0%, transparent 55%),
    radial-gradient(ellipse 40% 40% at 50% 10%, rgba(80,60,180,.14) 0%, transparent 55%);
}

/* floating orbs */
.orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(60px);
  animation: orbFloat 8s ease-in-out infinite;
  z-index: 0;
}
.orb-1 { width:320px; height:320px; background:rgba(201,120,58,.15); top:-80px; left:-80px; animation-delay:0s; }
.orb-2 { width:240px; height:240px; background:rgba(212,168,67,.12); bottom:120px; right:-60px; animation-delay:-3s; }
.orb-3 { width:180px; height:180px; background:rgba(80,120,220,.1); top:50%; left:40%; animation-delay:-5s; }
@keyframes orbFloat {
  0%,100% { transform: translateY(0) scale(1); }
  50%      { transform: translateY(-30px) scale(1.07); }
}

/* grid dots */
.auth-visual-grid {
  position: absolute;
  inset: 0;
  background-image: radial-gradient(rgba(255,255,255,.04) 1px, transparent 1px);
  background-size: 28px 28px;
  z-index: 0;
}

/* floating destination tags */
.dest-tags {
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
}
.dest-tag {
  position: absolute;
  background: rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.1);
  backdrop-filter: blur(10px);
  border-radius: 40px;
  padding: 8px 18px;
  font-family: 'DM Sans', sans-serif;
  font-size: 12px;
  font-weight: 500;
  color: rgba(255,255,255,.55);
  display: flex;
  align-items: center;
  gap: 7px;
  animation: tagDrift 10s ease-in-out infinite;
}
.dest-tag:nth-child(1) { top: 12%; left: 8%;  animation-delay: 0s; }
.dest-tag:nth-child(2) { top: 22%; right: 10%; animation-delay: -2s; }
.dest-tag:nth-child(3) { top: 42%; left: 5%;  animation-delay: -4s; }
.dest-tag:nth-child(4) { top: 60%; right: 8%; animation-delay: -6s; }
.dest-tag:nth-child(5) { top: 75%; left: 12%; animation-delay: -1s; }
@keyframes tagDrift {
  0%,100% { transform: translateY(0); opacity:.55; }
  50%      { transform: translateY(-10px); opacity:.8; }
}

.auth-visual-content { position: relative; z-index: 2; }
.auth-visual-logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px;
  font-weight: 600;
  color: #fff;
  letter-spacing: 2px;
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 48px;
}
.auth-visual-logo span {
  width: 8px; height: 8px;
  background: #d4a843;
  border-radius: 50%;
  display: inline-block;
}
.auth-visual-quote {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(32px, 3.5vw, 46px);
  font-weight: 300;
  color: #fff;
  line-height: 1.22;
  margin-bottom: 20px;
}
.auth-visual-quote em {
  font-style: italic;
  color: #d4a843;
}
.auth-visual-sub {
  font-size: 14px;
  color: rgba(255,255,255,.38);
  font-weight: 300;
  margin-bottom: 36px;
}
.auth-visual-stats {
  display: flex;
  gap: 32px;
}
.auth-stat-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 28px;
  font-weight: 600;
  color: #fff;
  line-height: 1;
}
.auth-stat-num span { color: #d4a843; }
.auth-stat-label {
  font-size: 11px;
  color: rgba(255,255,255,.35);
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-top: 4px;
}

/* ══ RIGHT PANEL — form ══ */
.auth-form-panel {
  width: 480px;
  flex-shrink: 0;
  background: #faf7f2;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 60px 52px;
  position: relative;
  overflow: hidden;
}
.auth-form-panel::before {
  content: '';
  position: absolute;
  top: -120px; right: -120px;
  width: 300px; height: 300px;
  background: radial-gradient(circle, rgba(201,120,58,.08) 0%, transparent 70%);
  pointer-events: none;
}
.auth-form-panel::after {
  content: '';
  position: absolute;
  bottom: -80px; left: -80px;
  width: 220px; height: 220px;
  background: radial-gradient(circle, rgba(212,168,67,.06) 0%, transparent 70%);
  pointer-events: none;
}

.auth-form-eyebrow {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #c9783a;
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.auth-form-eyebrow::after {
  content: '';
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, #c9783a44, transparent);
}
.auth-form-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 40px;
  font-weight: 600;
  color: #1a1a2e;
  line-height: 1.1;
  margin-bottom: 8px;
}
.auth-form-title em { font-style: italic; color: #c9783a; }
.auth-form-subtitle {
  font-size: 13.5px;
  color: #7a7a8a;
  margin-bottom: 36px;
  font-weight: 300;
}

/* flash messages */
.auth-flash {
  border-radius: 12px;
  padding: 12px 16px;
  font-size: 13px;
  font-weight: 500;
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.auth-flash-error {
  background: #fff1f0;
  border: 1px solid #ffd4d0;
  color: #c0392b;
}
.auth-flash-success {
  background: #f0fff4;
  border: 1px solid #b7ebc8;
  color: #27ae60;
}

/* form fields */
.auth-field { margin-bottom: 20px; position: relative; }
.auth-label {
  display: block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: #7a7a8a;
  margin-bottom: 8px;
}
.auth-input-wrap {
  position: relative;
  display: flex;
  align-items: center;
}
.auth-input-icon {
  position: absolute;
  left: 16px;
  color: #c0bab4;
  font-size: 15px;
  pointer-events: none;
  transition: color .2s;
  z-index: 1;
}
.auth-input {
  width: 100%;
  padding: 14px 16px 14px 44px;
  border: 2px solid #e8e2d9;
  border-radius: 12px;
  font-family: 'DM Sans', sans-serif;
  font-size: 14.5px;
  color: #1a1a2e;
  background: #fff;
  outline: none;
  transition: border-color .2s, box-shadow .2s, background .2s;
}
.auth-input::placeholder { color: #c0bab4; }
.auth-input:focus {
  border-color: #c9783a;
  box-shadow: 0 0 0 4px rgba(201,120,58,.1);
  background: #fffdf9;
}
.auth-input:focus ~ .auth-input-icon,
.auth-input-wrap:focus-within .auth-input-icon { color: #c9783a; }

/* password toggle */
.pw-toggle {
  position: absolute;
  right: 14px;
  background: none;
  border: none;
  cursor: pointer;
  color: #c0bab4;
  font-size: 15px;
  padding: 4px;
  transition: color .2s;
  z-index: 1;
}
.pw-toggle:hover { color: #c9783a; }

/* submit button */
.auth-submit-btn {
  width: 100%;
  padding: 15px;
  background: linear-gradient(135deg, #1a1a2e 0%, #2d2250 100%);
  color: white;
  border: none;
  border-radius: 12px;
  font-family: 'DM Sans', sans-serif;
  font-size: 15px;
  font-weight: 600;
  cursor: pointer;
  transition: all .25s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin-bottom: 20px;
  position: relative;
  overflow: hidden;
  letter-spacing: .3px;
}
.auth-submit-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(212,168,67,.25), transparent);
  opacity: 0;
  transition: opacity .25s;
}
.auth-submit-btn:hover::before { opacity: 1; }
.auth-submit-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(26,26,46,.35); }
.auth-submit-btn:active { transform: translateY(0); }

/* divider */
.auth-divider {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 20px;
  font-size: 12px;
  color: #b0a8a0;
}
.auth-divider::before, .auth-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: #e8e2d9;
}

/* switch link */
.auth-switch {
  text-align: center;
  font-size: 13.5px;
  color: #7a7a8a;
}
.auth-switch a {
  color: #c9783a;
  font-weight: 600;
  text-decoration: none;
  transition: color .2s;
}
.auth-switch a:hover { color: #a85e28; text-decoration: underline; }

/* trust badges */
.auth-trust {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20px;
  margin-top: 28px;
  padding-top: 20px;
  border-top: 1px solid #e8e2d9;
}
.auth-trust-item {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  color: #b0a8a0;
}
.auth-trust-item i { color: #d4a843; font-size: 12px; }

/* page entrance animation */
.auth-form-panel > * {
  animation: slideInRight .5s cubic-bezier(.25,.8,.25,1) both;
}
.auth-form-panel > *:nth-child(1) { animation-delay: .05s; }
.auth-form-panel > *:nth-child(2) { animation-delay: .1s; }
.auth-form-panel > *:nth-child(3) { animation-delay: .15s; }
.auth-form-panel > *:nth-child(4) { animation-delay: .2s; }
.auth-form-panel > *:nth-child(5) { animation-delay: .25s; }
@keyframes slideInRight {
  from { opacity:0; transform:translateX(24px); }
  to   { opacity:1; transform:translateX(0); }
}
.auth-visual-content > * {
  animation: slideInLeft .6s cubic-bezier(.25,.8,.25,1) both;
}
.auth-visual-content > *:nth-child(1) { animation-delay: .1s; }
.auth-visual-content > *:nth-child(2) { animation-delay: .2s; }
.auth-visual-content > *:nth-child(3) { animation-delay: .3s; }
.auth-visual-content > *:nth-child(4) { animation-delay: .4s; }
@keyframes slideInLeft {
  from { opacity:0; transform:translateX(-24px); }
  to   { opacity:1; transform:translateX(0); }
}

/* ══ RESPONSIVE ══ */
@media (max-width: 900px) {
  .auth-visual { display: none; }
  .auth-form-panel { width: 100%; padding: 48px 28px; min-height: 100vh; }
}
@media (max-width: 480px) {
  .auth-form-panel { padding: 36px 20px; }
  .auth-form-title { font-size: 32px; }
}
</style>

<div class="auth-page-wrapper">

  <!-- ══ LEFT: Visual Panel ══ -->
  <div class="auth-visual">
    <div class="auth-visual-bg"></div>
    <div class="auth-visual-grid"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <!-- floating destination tags -->
    <div class="dest-tags">
      <div class="dest-tag">🏖️ Goa, India</div>
      <div class="dest-tag">🏔️ Manali, Himachal</div>
      <div class="dest-tag">🛕 Puri, Odisha</div>
      <div class="dest-tag">💎 Udaipur, Rajasthan</div>
      <div class="dest-tag">🌴 Kerala Backwaters</div>
    </div>

    <div class="auth-visual-content">
      <div class="auth-visual-logo">
        <span></span> Wanderlust
      </div>
      <div class="auth-visual-quote">
        Every journey begins<br/>with a single <em>step</em>
      </div>
      <p class="auth-visual-sub">Your handpicked stays across India &amp; beyond — waiting for you.</p>
      <div class="auth-visual-stats">
        <div>
          <div class="auth-stat-num">500<span>+</span></div>
          <div class="auth-stat-label">Stays</div>
        </div>
        <div>
          <div class="auth-stat-num">80<span>+</span></div>
          <div class="auth-stat-label">Cities</div>
        </div>
        <div>
          <div class="auth-stat-num">4.8<span>★</span></div>
          <div class="auth-stat-label">Rating</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ RIGHT: Form Panel ══ -->
  <div class="auth-form-panel">

    <!-- Flash messages -->
    <% if(success && success.length) { %>
      <div class="auth-flash auth-flash-success">
        <i class="fa-solid fa-circle-check"></i> <%= success %>
      </div>
    <% } %>
    <% if(error && error.length) { %>
      <div class="auth-flash auth-flash-error">
        <i class="fa-solid fa-triangle-exclamation"></i> <%= error %>
      </div>
    <% } %>

    <div class="auth-form-eyebrow">Welcome back</div>
    <h1 class="auth-form-title">Sign <em>in</em> to<br/>your account</h1>
    <p class="auth-form-subtitle">Pick up where your last adventure left off</p>

    <form action="/login" method="POST" class="needs-validation" novalidate>

      <div class="auth-field">
        <label class="auth-label" for="username">Username</label>
        <div class="auth-input-wrap">
          <i class="fa-solid fa-user auth-input-icon"></i>
          <input
            type="text"
            id="username"
            name="username"
            class="auth-input"
            placeholder="Enter your username"
            autocomplete="username"
            required
          />
        </div>
      </div>

      <div class="auth-field">
        <label class="auth-label" for="password">Password</label>
        <div class="auth-input-wrap">
          <i class="fa-solid fa-lock auth-input-icon"></i>
          <input
            type="password"
            id="password"
            name="password"
            class="auth-input"
            placeholder="Enter your password"
            autocomplete="current-password"
            required
          />
          <button type="button" class="pw-toggle" onclick="togglePw('password', this)" tabindex="-1">
            <i class="fa-regular fa-eye"></i>
          </button>
        </div>
      </div>

      <button type="submit" class="auth-submit-btn">
        <i class="fa-solid fa-arrow-right-to-bracket"></i>
        Sign In
      </button>

    </form>

    <div class="auth-divider">or</div>

    <div class="auth-switch">
      New to Wanderlust?
      <a href="/signup">Create an account →</a>
    </div>

    <div class="auth-trust">
      <div class="auth-trust-item"><i class="fa-solid fa-shield-halved"></i> Secure login</div>
      <div class="auth-trust-item"><i class="fa-solid fa-lock"></i> Encrypted</div>
      <div class="auth-trust-item"><i class="fa-solid fa-user-shield"></i> Private</div>
    </div>

  </div>
</div>

<script>
function togglePw(fieldId, btn) {
  const input = document.getElementById(fieldId);
  const icon  = btn.querySelector('i');
  if (input.type === 'password') {
    input.type = 'text';
    icon.className = 'fa-regular fa-eye-slash';
  } else {
    input.type = 'password';
    icon.className = 'fa-regular fa-eye';
  }
}
</script>
