<% layout("/layouts/boilerplate") %>

<style>
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&family=DM+Sans:wght@300;400;500;600&display=swap');

.fp-wrapper {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #080810;
  padding: 24px;
  position: relative;
  overflow: hidden;
  font-family: 'DM Sans', sans-serif;
}
.fp-wrapper::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 50% at 20% 40%, rgba(201,120,58,.14) 0%, transparent 60%),
    radial-gradient(ellipse 50% 60% at 80% 60%, rgba(212,168,67,.1) 0%, transparent 55%);
}
.fp-wrapper::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(rgba(255,255,255,.03) 1px, transparent 1px);
  background-size: 28px 28px;
}

/* ── card ── */
.fp-card {
  background: #faf7f2;
  border-radius: 28px;
  width: 100%;
  max-width: 440px;
  padding: 48px 44px;
  position: relative;
  z-index: 1;
  box-shadow: 0 32px 80px rgba(0,0,0,.5);
  animation: cardReveal .5s cubic-bezier(.34,1.56,.64,1) both;
}
@keyframes cardReveal {
  from { opacity:0; transform:translateY(30px) scale(.96); }
  to   { opacity:1; transform:translateY(0) scale(1); }
}
.fp-card::before {
  content: '';
  position: absolute;
  top: -1px; left: -1px; right: -1px; bottom: -1px;
  border-radius: 28px;
  background: linear-gradient(135deg, rgba(212,168,67,.3), rgba(201,120,58,.2), transparent 60%);
  z-index: -1;
}

/* icon */
.fp-icon-wrap {
  width: 72px; height: 72px;
  background: linear-gradient(135deg, #1a1a2e, #2d2250);
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30px;
  margin: 0 auto 24px;
  box-shadow: 0 8px 24px rgba(26,26,46,.3);
  animation: iconPop .6s cubic-bezier(.34,1.56,.64,1) .2s both;
}
@keyframes iconPop {
  from { opacity:0; transform:scale(.5); }
  to   { opacity:1; transform:scale(1); }
}

/* steps indicator */
.fp-steps {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  margin-bottom: 28px;
}
.fp-step-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  background: #e0d8cc;
  transition: all .3s;
}
.fp-step-dot.active { background: #c9783a; box-shadow: 0 0 0 3px rgba(201,120,58,.2); }
.fp-step-dot.done   { background: #27ae60; }
.fp-step-line {
  width: 40px; height: 2px;
  background: #e0d8cc;
  transition: background .3s;
}
.fp-step-line.done { background: #27ae60; }

.fp-eyebrow {
  text-align: center;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #c9783a;
  margin-bottom: 10px;
}
.fp-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 34px;
  font-weight: 600;
  color: #1a1a2e;
  text-align: center;
  margin-bottom: 8px;
  line-height: 1.15;
}
.fp-title em { font-style: italic; color: #c9783a; }
.fp-subtitle {
  text-align: center;
  font-size: 13.5px;
  color: #7a7a8a;
  margin-bottom: 32px;
  font-weight: 300;
  line-height: 1.6;
}

/* flash */
.fp-flash {
  border-radius: 12px;
  padding: 12px 16px;
  font-size: 13px;
  font-weight: 500;
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.fp-flash-error   { background: #fff1f0; border: 1px solid #ffd4d0; color: #c0392b; }
.fp-flash-success { background: #f0fff4; border: 1px solid #b7ebc8; color: #27ae60; }

/* field */
.fp-field { margin-bottom: 20px; }
.fp-label {
  display: block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: #7a7a8a;
  margin-bottom: 8px;
}
.fp-input-wrap { position: relative; display: flex; align-items: center; }
.fp-input-icon {
  position: absolute;
  left: 16px;
  color: #c0bab4;
  font-size: 15px;
  pointer-events: none;
  transition: color .2s;
}
.fp-input {
  width: 100%;
  padding: 14px 16px 14px 44px;
  border: 2px solid #e8e2d9;
  border-radius: 12px;
  font-family: 'DM Sans', sans-serif;
  font-size: 14.5px;
  color: #1a1a2e;
  background: #fff;
  outline: none;
  transition: border-color .2s, box-shadow .2s;
}
.fp-input::placeholder { color: #c0bab4; }
.fp-input:focus {
  border-color: #c9783a;
  box-shadow: 0 0 0 4px rgba(201,120,58,.1);
}
.fp-input:focus + .fp-input-icon { color: #c9783a; }
.fp-input-wrap:focus-within .fp-input-icon { color: #c9783a; }

/* submit */
.fp-btn {
  width: 100%;
  padding: 15px;
  background: linear-gradient(135deg, #1a1a2e 0%, #2d2250 100%);
  color: white;
  border: none;
  border-radius: 12px;
  font-family: 'DM Sans', sans-serif;
  font-size: 15px;
  font-weight: 600;
  cursor: pointer;
  transition: all .25s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin-bottom: 18px;
  position: relative;
  overflow: hidden;
}
.fp-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(212,168,67,.25), transparent);
  opacity: 0;
  transition: opacity .25s;
}
.fp-btn:hover::before { opacity: 1; }
.fp-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(26,26,46,.35); }

/* back link */
.fp-back {
  text-align: center;
  font-size: 13px;
  color: #7a7a8a;
}
.fp-back a {
  color: #c9783a;
  font-weight: 600;
  text-decoration: none;
  transition: color .2s;
}
.fp-back a:hover { color: #a85e28; text-decoration: underline; }

/* loading state */
.fp-btn.loading .btn-text { display: none; }
.fp-btn.loading .btn-spinner { display: flex; }
.btn-spinner { display: none; align-items: center; gap: 8px; }
.spinner-ring {
  width: 18px; height: 18px;
  border: 2px solid rgba(255,255,255,.3);
  border-top-color: white;
  border-radius: 50%;
  animation: spin .7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
</style>

<div class="fp-wrapper">
  <div class="fp-card">

    <!-- icon -->
    <div class="fp-icon-wrap">🔐</div>

    <!-- steps: step 1 active -->
    <div class="fp-steps">
      <div class="fp-step-dot active"></div>
      <div class="fp-step-line"></div>
      <div class="fp-step-dot"></div>
      <div class="fp-step-line"></div>
      <div class="fp-step-dot"></div>
    </div>

    <!-- flash -->
    <% if(success && success.length) { %>
      <div class="fp-flash fp-flash-success">
        <i class="fa-solid fa-circle-check"></i> <%= success %>
      </div>
    <% } %>
    <% if(error && error.length) { %>
      <div class="fp-flash fp-flash-error">
        <i class="fa-solid fa-triangle-exclamation"></i> <%= error %>
      </div>
    <% } %>

    <div class="fp-eyebrow">Step 1 of 3</div>
    <h1 class="fp-title">Forgot your<br/><em>password?</em></h1>
    <p class="fp-subtitle">Enter your registered email and we'll send a 6-digit OTP to reset your password.</p>

    <form action="/forgot-password" method="POST" id="fpForm">
      <div class="fp-field">
        <label class="fp-label" for="email">Email Address</label>
        <div class="fp-input-wrap">
          <i class="fa-solid fa-envelope fp-input-icon"></i>
          <input
            type="email"
            id="email"
            name="email"
            class="fp-input"
            placeholder="your@email.com"
            autocomplete="email"
            required
          />
        </div>
      </div>

      <button type="submit" class="fp-btn" id="fpBtn">
        <span class="btn-text">
          <i class="fa-solid fa-paper-plane"></i> Send OTP
        </span>
        <span class="btn-spinner">
          <span class="spinner-ring"></span> Sending…
        </span>
      </button>
    </form>

    <div class="fp-back">
      Remember it? <a href="/login">← Back to Login</a>
    </div>

  </div>
</div>

<script>
document.getElementById('fpForm').addEventListener('submit', function() {
  const btn = document.getElementById('fpBtn');
  btn.classList.add('loading');
  btn.disabled = true;
});
</script>
